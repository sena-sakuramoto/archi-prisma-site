---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  darkSpace?: boolean;
  ogImage?: string;
  preloadImages?: string[];
}

const {
  title = 'Archi-Prisma Design Works | Architecture × Software — Tokyo / London',
  description = 'Archi-Prisma Design Works は建築設計とソフトウェア開発の二軸で、AI × 建築の未来を切り拓く設計事務所です。Tokyo / London.',
  darkSpace = false,
  ogImage = 'https://archi-prisma.co.jp/assets/og-image.png',
  preloadImages = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://archi-prisma.co.jp');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Archi-Prisma Design Works',
  alternateName: 'APDW',
  url: 'https://archi-prisma.co.jp',
  logo: 'https://archi-prisma.co.jp/assets/branding/apdw-logo.png',
  description: 'Architecture × Software design firm. Tokyo / London.',
  address: [
    {
      '@type': 'PostalAddress',
      addressLocality: 'Tokyo',
      addressCountry: 'JP',
    },
    {
      '@type': 'PostalAddress',
      addressLocality: 'London',
      addressCountry: 'GB',
    },
  ],
  sameAs: ['https://ai-archi-circle.jp'],
};
---

<!doctype html>
<html lang="ja" class={darkSpace ? 'dark-space' : ''}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- OGP -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Preload critical assets (per-page) -->
    {preloadImages.map((src) => (
      <link rel="preload" href={src} as="image" type="image/jpeg" />
    ))}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: Syne + Outfit + Noto Sans JP -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Outfit:wght@200;300;400;500&family=Noto+Sans+JP:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Organization schema -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- View Transitions for seamless page navigation -->
    <ViewTransitions />
  </head>
  <body>
    <slot />
  </body>
</html>
