---
// WorksModal — Project detail modal markup (no script, just structure)
---

<div id="project-modal" class="modal" role="dialog" aria-modal="true" aria-label="プロジェクト詳細" hidden>
  <div class="modal__backdrop"></div>
  <div class="modal__panel">
    <button class="modal__close" type="button" aria-label="閉じる">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <div class="modal__image-area">
      <img id="modal-img" class="modal__img" src="" alt="" width="1920" height="823" />
    </div>
    <div class="modal__info">
      <span class="modal__meta" id="modal-meta"></span>
      <h2 class="modal__title" id="modal-title"></h2>
      <p class="modal__description text-measure" id="modal-description"></p>
      <p class="modal__story text-measure" id="modal-story"></p>
      <dl class="modal__details" id="modal-details"></dl>
      <div class="modal__actions">
        <a href="" class="modal__page-link" id="modal-page-link">詳細ページを見る →</a>
        <a href="/contact/" class="modal__contact-link" id="modal-contact">この実績について相談する</a>
      </div>
      <div class="modal__nav">
        <button class="modal__nav-btn" id="modal-prev" type="button" aria-label="前のプロジェクト">← Prev</button>
        <button class="modal__nav-btn" id="modal-next" type="button" aria-label="次のプロジェクト">Next →</button>
      </div>
    </div>
  </div>
</div>

<style>
  .modal {
    position: fixed; inset: 0; z-index: 1000;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity 0.3s var(--ease);
    pointer-events: none;
  }
  .modal[hidden] { display: none; }
  .modal--open { opacity: 1; pointer-events: auto; }
  .modal__backdrop {
    position: absolute; inset: 0;
    background: rgba(0,0,0,0.85); backdrop-filter: blur(8px);
  }
  .modal__panel {
    position: relative; z-index: 1;
    display: grid; grid-template-columns: 1fr;
    max-width: 1100px; width: calc(100% - 2rem); max-height: calc(100vh - 4rem);
    overflow-y: auto; border-radius: 6px;
    background: var(--color-surface);
    transform: scale(0.95); transition: transform 0.3s var(--ease);
  }
  .modal--open .modal__panel { transform: scale(1); }
  @media (min-width: 768px) {
    .modal__panel {
      grid-template-columns: 1.2fr 1fr; overflow-y: hidden;
    }
  }
  .modal__close {
    position: absolute; top: 1rem; right: 1rem; z-index: 2;
    background: rgba(0,0,0,0.5); border: none; border-radius: 50%;
    width: 40px; height: 40px; display: flex; align-items: center;
    justify-content: center; cursor: pointer; color: white;
    transition: background 0.2s;
  }
  .modal__close:hover { background: rgba(0,0,0,0.8); }
  .modal__close:focus-visible {
    outline: 2px solid var(--color-accent-dark);
    outline-offset: 2px;
  }
  .modal__image-area {
    background: var(--color-surface-dark); overflow: hidden;
    min-height: 250px; display: flex; align-items: center; justify-content: center;
  }
  .modal__img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  @media (min-width: 768px) {
    .modal__image-area { max-height: calc(100vh - 4rem); }
  }
  .modal__info {
    padding: clamp(2rem, 4vw, 3rem); display: flex;
    flex-direction: column; justify-content: center;
  }
  .modal__meta {
    font-family: var(--font-body); font-size: var(--text-caption);
    color: var(--color-ink-muted); letter-spacing: 0.15em;
    text-transform: uppercase; margin-bottom: 0.75rem;
  }
  .modal__title {
    font-family: var(--font-display); font-size: var(--text-project);
    font-weight: 700; margin-bottom: 1rem; line-height: 1.2;
  }
  .modal__description {
    font-family: var(--font-jp); font-size: var(--text-body);
    color: var(--color-ink); line-height: 2; margin-bottom: 1rem;
  }
  .modal__story {
    font-family: var(--font-jp); font-size: var(--text-body);
    color: var(--color-ink-muted); line-height: 2; margin-bottom: 1.5rem;
    font-style: italic;
  }
  .modal__details {
    font-family: var(--font-body); font-size: var(--text-caption);
    color: var(--color-ink-muted); margin-bottom: 1.5rem;
    display: flex; flex-direction: column; gap: 0.4rem;
  }
  .modal__detail-row {
    display: flex; gap: 1rem; align-items: baseline;
  }
  .modal__detail-row dt {
    font-weight: 600; color: var(--color-ink);
    letter-spacing: 0.1em; text-transform: uppercase;
    min-width: 5rem; flex-shrink: 0;
  }
  .modal__detail-row dd {
    color: var(--color-ink-muted);
  }
  .modal__actions {
    display: flex; flex-direction: column; gap: 0.75rem;
    margin-bottom: 2rem; align-self: flex-start;
  }
  .modal__page-link {
    font-family: var(--font-display); font-size: 0.85rem; font-weight: 600;
    letter-spacing: 0.08em; padding: 0.7rem 1.75rem; border-radius: 3px;
    background: var(--color-ink); color: var(--color-surface);
    text-decoration: none; text-align: center;
    transition: background 0.25s var(--ease);
  }
  .modal__page-link:hover,
  .modal__page-link:focus-visible { background: var(--color-accent); }
  .modal__contact-link {
    font-family: var(--font-display); font-size: 0.8rem; font-weight: 600;
    letter-spacing: 0.08em; color: var(--color-accent);
    text-decoration: none; text-align: center;
    transition: color 0.2s var(--ease);
  }
  .modal__contact-link:hover,
  .modal__contact-link:focus-visible { color: var(--color-ink); }
  .modal__nav {
    display: flex; gap: 1rem; margin-top: auto;
  }
  .modal__nav-btn {
    font-family: var(--font-display); font-size: 0.8rem; font-weight: 600;
    letter-spacing: 0.08em; padding: 0.6rem 1.5rem; border-radius: 3px;
    border: 1px solid var(--color-rule); background: transparent;
    color: var(--color-ink); cursor: pointer; transition: all 0.2s var(--ease);
  }
  .modal__nav-btn:hover:not(:disabled) {
    background: var(--color-ink); color: var(--color-surface);
  }
  .modal__nav-btn:disabled { opacity: 0.3; cursor: default; }
  .modal__nav-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>
