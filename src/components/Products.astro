---
/**
 * Products — Task 12
 * Dark Space section (.dark-space). Three products with line-section layouts.
 * COMPASS 45|55, KAKOME 60|40 reversed, KOZO 40|60.
 */

const products = [
  {
    id: 'products-compass',
    linePos: '45%',
    logo: '/assets/products/compass-logo.png',
    logoAlt: 'COMPASS',
    screenshot: '/assets/curated/compass-gantt-ui.png',
    tagline: '工程管理',
    name: 'COMPASS',
    description: '建設プロジェクトの工程管理をシンプルに。AI補助で予定立案から進捗追跡まで、現場と設計室をつなぐ。',
    layout: 'normal',
  },
  {
    id: 'products-kakome',
    linePos: '60%',
    logo: '/assets/products/kakome-logo-black.png',
    logoAlt: 'KAKOME',
    screenshot: null,
    tagline: '写真指示書',
    name: 'KAKOME',
    description: '現場写真に指示を重ねて共有。口頭では伝わらないニュアンスを、ビジュアルで確実に届ける。',
    layout: 'reversed',
  },
  {
    id: 'products-kozo',
    linePos: '40%',
    logo: '/assets/products/kozo-logo.png',
    logoAlt: 'KOZO',
    screenshot: null,
    tagline: '構造計算AI',
    name: 'KOZO',
    description: '構造計算の煩雑な作業をAIがアシスト。法改正にも素早く対応、設計事務所の負担を根本から減らす。',
    layout: 'normal',
  },
];
---

<section
  class="dark-space"
  aria-label="Software Products"
  style="padding-top: clamp(64px, 8vw, 120px);"
>
  <!-- Section header -->
  <div
    style="max-width: var(--max-width); margin: 0 auto; padding: 0 var(--content-padding-x) clamp(40px, 6vw, 80px);"
  >
    <div style="display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 24px;">
      <img
        src="/assets/branding/apdw-logotype.png"
        alt="Archi-Prisma Design Works"
        class="invert"
        style="height: 32px; width: auto; display: block;"
      />
      <p
        style="font-family: var(--font-display); font-size: var(--text-nav); font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-ink-muted-dark); margin: 0;"
      >
        Software Development
      </p>
    </div>
  </div>

  <!-- Products -->
  {
    products.map((p) => (
      <div
        id={p.id}
        style={`--line-pos: ${p.linePos}; border-top: 1px solid rgba(196, 168, 130, 0.2);`}
      >
        {p.layout === 'normal' && (
          <div
            class="line-section"
            style="align-items: stretch;"
          >
            {/* Left: product info */}
            <div
              style="padding: clamp(48px, 7vw, 96px) 40px clamp(48px, 7vw, 96px) 0; display: flex; flex-direction: column; justify-content: center; gap: 24px;"
            >
              <img
                src={p.logo}
                alt={p.logoAlt}
                class="invert"
                style="height: 40px; width: auto; display: block; object-fit: contain; object-position: left center;"
                loading="lazy"
              />
              <p
                style="font-family: var(--font-display); font-size: var(--text-nav); font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-accent-dark); margin: 0;"
              >
                {p.tagline}
              </p>
              <p
                style="font-family: var(--font-jp); font-size: var(--text-body); line-height: 1.9; color: var(--color-ink-muted-dark); margin: 0; max-width: 36ch;"
              >
                {p.description}
              </p>
            </div>

            <div class="dividing-line" aria-hidden="true" />

            {/* Right: screenshot or placeholder */}
            <div
              style="min-height: 280px; display: flex; align-items: center; justify-content: center; overflow: hidden; padding: clamp(40px, 5vw, 64px) 0 clamp(40px, 5vw, 64px) 40px;"
            >
              {p.screenshot ? (
                <img
                  src={p.screenshot}
                  alt={`${p.name} screenshot`}
                  loading="lazy"
                  style="width: 100%; height: auto; display: block; border-radius: 4px; opacity: 0.9;"
                />
              ) : (
                <div
                  style="width: 100%; aspect-ratio: 16/9; border: 1px solid rgba(196,168,130,0.15); display: flex; align-items: center; justify-content: center; border-radius: 4px;"
                >
                  <p
                    style="font-family: var(--font-display); font-size: var(--text-caption); letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-ink-muted-dark); margin: 0;"
                  >
                    Coming Soon
                  </p>
                </div>
              )}
            </div>
          </div>
        )}

        {p.layout === 'reversed' && (
          <div
            class="line-section"
            style="align-items: stretch;"
          >
            {/* Left: screenshot/placeholder (60%) */}
            <div
              style="min-height: 280px; display: flex; align-items: center; justify-content: center; overflow: hidden; padding: clamp(40px, 5vw, 64px) 40px clamp(40px, 5vw, 64px) 0;"
            >
              {p.screenshot ? (
                <img
                  src={p.screenshot}
                  alt={`${p.name} screenshot`}
                  loading="lazy"
                  style="width: 100%; height: auto; display: block; border-radius: 4px; opacity: 0.9;"
                />
              ) : (
                <div
                  style="width: 100%; aspect-ratio: 16/9; border: 1px solid rgba(196,168,130,0.15); display: flex; align-items: center; justify-content: center; border-radius: 4px;"
                >
                  <p
                    style="font-family: var(--font-display); font-size: var(--text-caption); letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-ink-muted-dark); margin: 0;"
                  >
                    Coming Soon
                  </p>
                </div>
              )}
            </div>

            <div class="dividing-line" aria-hidden="true" />

            {/* Right: product info (40%) */}
            <div
              style="padding: clamp(48px, 7vw, 96px) 0 clamp(48px, 7vw, 96px) 40px; display: flex; flex-direction: column; justify-content: center; gap: 24px;"
            >
              <img
                src={p.logo}
                alt={p.logoAlt}
                class="invert"
                style="height: 40px; width: auto; display: block; object-fit: contain; object-position: left center;"
                loading="lazy"
              />
              <p
                style="font-family: var(--font-display); font-size: var(--text-nav); font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-accent-dark); margin: 0;"
              >
                {p.tagline}
              </p>
              <p
                style="font-family: var(--font-jp); font-size: var(--text-body); line-height: 1.9; color: var(--color-ink-muted-dark); margin: 0; max-width: 36ch;"
              >
                {p.description}
              </p>
            </div>
          </div>
        )}
      </div>
    ))
  }

  <!-- CTA -->
  <div
    style="border-top: 1px solid rgba(196, 168, 130, 0.2); padding: clamp(40px, 5vw, 64px) var(--content-padding-x); max-width: var(--max-width); margin: 0 auto; text-align: center;"
  >
    <p
      style="font-family: var(--font-jp); font-size: var(--text-body); line-height: 1.9; color: var(--color-ink-muted-dark); max-width: 48ch; margin: 0 auto 32px;"
    >
      AI建築サークルに入れば、すべてのツールが使い放題。
    </p>
    <a
      href="https://ai-archi-circle.jp"
      target="_blank"
      rel="noopener noreferrer"
      class="link-animated"
      style="font-family: var(--font-display); font-size: var(--text-nav); font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-ink-dark); text-decoration: none;"
    >
      AI建築サークルで、すべてのツールが使い放題 →
    </a>
  </div>
</section>
