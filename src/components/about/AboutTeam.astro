---
// AboutTeam.astro — Team section with CEO, members, collaborators, advisory
import type { TeamMember } from '../../lib/content';

interface Props {
  team: {
    core: TeamMember[];
    advisory_legacy: TeamMember[];
    collaborators: TeamMember[];
  };
}

const { team } = Astro.props;
---

<section class="about-team">
  <div class="about-team__inner">
    <h2 class="about-team__heading reveal">Team</h2>

    <!-- CEO -->
    {team.core.length > 0 && (
      <div class="about-team__ceo reveal">
        <div class="about-team__ceo-img-wrap">
          <img
            src={team.core[0].image}
            alt={team.core[0].name}
            loading="lazy"
            class="about-team__ceo-img"
            width="400"
            height="533"
          />
        </div>
        <div class="about-team__ceo-info">
          <span class="about-team__role">{team.core[0].role}</span>
          <h3 class="about-team__name">{team.core[0].name}</h3>
          <p class="about-team__notes text-measure">{team.core[0].notes}</p>
        </div>
      </div>
    )}

    <!-- Members -->
    {team.core.length > 1 && (
      <div class="about-team__members">
        {team.core.slice(1).map((member, i) => (
          <div class="about-team__member reveal" style={`--delay: ${i * 0.08}s`}>
            <div class="about-team__member-img-wrap">
              <img
                src={member.image}
                alt={member.name}
                loading="lazy"
                class="about-team__member-img"
                width="400"
                height="533"
              />
            </div>
            <h4 class="about-team__member-name">{member.name}</h4>
            <span class="about-team__member-role">{member.role}</span>
            {member.license && (
              <span class="about-team__member-license">{member.license}</span>
            )}
          </div>
        ))}
      </div>
    )}

    <!-- Collaborators -->
    <div class="about-team__collab reveal">
      <h3 class="about-team__sub-heading">International Collaborators</h3>
      <div class="about-team__collab-list">
        {team.collaborators.map((c) => (
          <div class="about-team__collab-item">
            <span class="about-team__collab-name">{c.name}</span>
            <span class="about-team__collab-role">{c.role}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Advisory -->
    <div class="about-team__advisory reveal">
      <h3 class="about-team__sub-heading">Advisory &amp; Legacy</h3>
      <div class="about-team__advisory-list">
        {team.advisory_legacy.map((a) => (
          <div class="about-team__advisory-item">
            <span class="about-team__collab-name">{a.name}</span>
            <p class="about-team__advisory-notes">{a.notes}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about-team {
    padding: 0 0 8rem;
  }
  .about-team__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--content-padding-x);
  }
  .about-team__heading {
    font-family: var(--font-display);
    font-size: var(--text-section);
    font-weight: 700;
    margin-bottom: 3rem;
  }

  /* CEO */
  .about-team__ceo {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    margin-bottom: 4rem;
  }
  @media (min-width: 768px) {
    .about-team__ceo {
      grid-template-columns: 320px 1fr;
      gap: 3rem;
    }
  }
  .about-team__ceo-img-wrap {
    overflow: hidden;
    border-radius: 3px;
    aspect-ratio: 3/4;
    max-width: 320px;
  }
  .about-team__ceo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .about-team__ceo-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .about-team__role {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    color: var(--color-ink-muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .about-team__name {
    font-family: var(--font-display);
    font-size: var(--text-project);
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .about-team__notes {
    font-family: var(--font-jp);
    font-size: var(--text-body);
    color: var(--color-ink-muted);
    line-height: 2;
    max-width: 480px;
  }

  /* Members */
  .about-team__members {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
  }
  .about-team__member-img-wrap {
    overflow: hidden;
    border-radius: 3px;
    aspect-ratio: 3/4;
    margin-bottom: 1rem;
    background: #eee;
  }
  .about-team__member-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .about-team__member-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }
  .about-team__member-role {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    color: var(--color-ink-muted);
    display: block;
  }
  .about-team__member-license {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--color-ink-muted);
    display: block;
    margin-top: 0.15rem;
  }

  /* Sub-headings */
  .about-team__sub-heading {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    color: var(--color-ink-muted);
  }

  /* Collaborators */
  .about-team__collab {
    margin-bottom: 3rem;
  }
  .about-team__collab-list {
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .about-team__collab-name {
    font-family: var(--font-display);
    font-size: var(--text-body);
    font-weight: 600;
    display: block;
  }
  .about-team__collab-role {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    color: var(--color-ink-muted);
    display: block;
  }

  /* Advisory */
  .about-team__advisory-list {
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .about-team__advisory-item {
    max-width: 320px;
  }
  .about-team__advisory-notes {
    font-family: var(--font-jp);
    font-size: var(--text-caption);
    color: var(--color-ink-muted);
    line-height: 1.7;
    margin-top: 0.25rem;
  }
</style>
