---
// AboutNetwork.astro — Global network with offices
interface Props {
  offices: {
    city: string;
    label: string;
    address: string;
    details: string;
  }[];
}

const { offices } = Astro.props;
const [tokyo, london] = offices;
---

<section class="about-network">
  <div class="about-network__inner">
    <h2 class="about-network__heading reveal">Global Network</h2>
  </div>

  <!-- Full-bleed heritage image -->
  <div class="about-network__image-bleed reveal img-grain">
    <img
      src="/assets/generated/about-heritage.jpg"
      alt="London and Tokyo — the two cities that shaped Archi-Prisma"
      loading="lazy"
      class="img-graded img-diagonal img-ken-burns"
      width="1920"
      height="823"
    />
  </div>

  <div class="about-network__inner">
    <!-- Pull-quote / statistic between image and offices -->
    <div class="about-network__stat reveal">
      <span class="about-network__stat-num">25+</span>
      <span class="about-network__stat-text">年、東京とロンドンを拠点に国際案件を手がけてきた実績</span>
    </div>

    <!-- Asymmetric office layout: Tokyo primary, London secondary -->
    <div class="about-network__offices">
      {tokyo && (
        <div class="about-network__office about-network__office--primary reveal">
          <span class="about-network__city">{tokyo.city}</span>
          <span class="about-network__label">{tokyo.label}</span>
          <p class="about-network__address">{tokyo.address}</p>
          <p class="about-network__details">{tokyo.details}</p>
        </div>
      )}
      {london && (
        <div class="about-network__office about-network__office--secondary reveal" style="--delay: 0.1s">
          <span class="about-network__city">{london.city}</span>
          <span class="about-network__label">{london.label}</span>
          <p class="about-network__address">{london.address}</p>
          <p class="about-network__details">{london.details}</p>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .about-network {
    padding: 0 0 8rem;
  }
  .about-network__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--content-padding-x);
  }
  .about-network__heading {
    font-family: var(--font-display);
    font-size: var(--text-section);
    font-weight: 700;
    margin-bottom: 3rem;
  }

  /* Full-bleed image — breaks out of container */
  .about-network__image-bleed {
    position: relative;
    overflow: hidden;
    margin-bottom: 3rem;
    aspect-ratio: 21/9;
    width: 100%;
  }
  .about-network__image-bleed img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Pull-quote / statistic */
  .about-network__stat {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 2.5rem 0 3rem;
    border-bottom: 1px solid var(--color-rule);
    margin-bottom: 2.5rem;
  }
  .about-network__stat-num {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-accent);
    line-height: 1;
    flex-shrink: 0;
  }
  .about-network__stat-text {
    font-family: var(--font-jp);
    font-size: clamp(0.85rem, 1.2vw, 1rem);
    font-weight: 400;
    color: var(--color-ink-muted);
    line-height: 1.8;
  }

  /* Asymmetric office grid: Tokyo full-width, London smaller */
  .about-network__offices {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .about-network__offices {
      grid-template-columns: 2fr 1fr;
      gap: 2rem;
    }
  }
  .about-network__office {
    padding: 2rem;
    border: 1px solid var(--color-rule);
    border-radius: 3px;
    transition: background-color 0.3s var(--ease);
  }
  .about-network__office:hover {
    background-color: rgba(0, 0, 0, 0.02);
  }

  /* Primary office (Tokyo) — larger text */
  .about-network__office--primary .about-network__city {
    font-size: clamp(2rem, 4vw, 3.5rem);
  }

  /* Secondary office (London) — standard size */
  .about-network__office--secondary {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .about-network__city {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    display: block;
    margin-bottom: 0.25rem;
  }
  .about-network__label {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    color: var(--color-accent);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 1rem;
  }
  .about-network__address {
    font-family: var(--font-jp);
    font-size: var(--text-body);
    color: var(--color-ink-muted);
    line-height: 1.7;
  }
  .about-network__details {
    font-family: var(--font-jp);
    font-size: var(--text-caption);
    color: var(--color-ink-muted);
    margin-top: 0.5rem;
  }
</style>
