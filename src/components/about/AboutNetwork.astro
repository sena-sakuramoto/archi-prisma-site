---
// AboutNetwork.astro — Global network with offices
interface Props {
  offices: {
    city: string;
    label: string;
    address: string;
    details: string;
  }[];
}

const { offices } = Astro.props;
---

<section class="about-network">
  <div class="about-network__inner">
    <h2 class="about-network__heading reveal">Global Network</h2>
    <div class="about-network__image reveal img-grain">
      <img
        src="/assets/generated/about-heritage.jpg"
        alt="London and Tokyo — the two cities that shaped Archi-Prisma"
        loading="lazy"
        class="img-graded img-diagonal img-ken-burns"
      />
    </div>
    <div class="about-network__offices">
      {offices.map((office, i) => (
        <div class="about-network__office reveal" style={`--delay: ${i * 0.1}s`}>
          <span class="about-network__city">{office.city}</span>
          <span class="about-network__label">{office.label}</span>
          <p class="about-network__address">{office.address}</p>
          <p class="about-network__details">{office.details}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .about-network {
    padding: 0 0 8rem;
  }
  .about-network__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--content-padding-x);
  }
  .about-network__heading {
    font-family: var(--font-display);
    font-size: var(--text-section);
    font-weight: 700;
    margin-bottom: 3rem;
  }
  .about-network__image {
    position: relative;
    overflow: hidden;
    border-radius: 4px;
    margin-bottom: 3rem;
    aspect-ratio: 21/9;
  }
  .about-network__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .about-network__offices {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .about-network__offices {
      grid-template-columns: 1fr 1fr;
    }
  }
  .about-network__office {
    padding: 2rem;
    border: 1px solid var(--color-rule);
    border-radius: 3px;
    transition: background-color 0.3s var(--ease);
  }
  .about-network__office:hover {
    background-color: rgba(0, 0, 0, 0.02);
  }
  .about-network__city {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    display: block;
    margin-bottom: 0.25rem;
  }
  .about-network__label {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    color: var(--color-accent);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 1rem;
  }
  .about-network__address {
    font-family: var(--font-jp);
    font-size: var(--text-body);
    color: var(--color-ink-muted);
    line-height: 1.7;
  }
  .about-network__details {
    font-family: var(--font-jp);
    font-size: var(--text-caption);
    color: var(--color-ink-muted);
    margin-top: 0.5rem;
  }
</style>
