---
// AboutPartners.astro — Partners grid
import type { Partner } from '../../lib/content';

interface Props {
  partners: Partner[];
}

const { partners } = Astro.props;
---

<section class="about-partners">
  <div class="about-partners__inner">
    <h2 class="about-partners__heading reveal">Partners</h2>
    <div class="about-partners__grid">
      {partners.map((partner, i) => (
        <div class="about-partners__card reveal" style={`--delay: ${i * 0.08}s`}>
          <img
            src={partner.logo}
            alt={partner.logoAlt}
            loading="lazy"
            class="about-partners__logo"
            style={`height: ${(partner.logoScale || 1) * 40}px`}
          />
          <h3 class="about-partners__name">{partner.name}</h3>
          <span class="about-partners__area">{partner.area}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .about-partners {
    padding: 0 0 8rem;
  }
  .about-partners__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--content-padding-x);
  }
  .about-partners__heading {
    font-family: var(--font-display);
    font-size: var(--text-section);
    font-weight: 700;
    margin-bottom: 3rem;
  }
  .about-partners__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 2rem;
  }
  .about-partners__card {
    text-align: center;
    padding: 2rem 1.5rem;
    border: 1px solid var(--color-rule);
    border-radius: 3px;
  }
  .about-partners__logo {
    width: auto;
    margin: 0 auto 1.25rem;
    display: block;
    opacity: 0.85;
  }
  .about-partners__name {
    font-family: var(--font-jp);
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 0.35rem;
  }
  .about-partners__area {
    font-family: var(--font-jp);
    font-size: var(--text-caption);
    color: var(--color-ink-muted);
  }
</style>
