---
/**
 * Hero — Line position: 30|70
 * Left: ARCHI-PRISMA logotype, Est. 2024, Tokyo / London, tagline
 * Right: Hero image with WebGL "Architectural Lens" effect (desktop)
 * Staggered reveal on load; image via clip-path + WebGL blur→focus
 */
---

<section
  id="hero"
  class="hero-home relative overflow-hidden"
  style="min-height: calc(100svh - var(--header-height)); padding-top: var(--header-height);"
>
  <div
    class="hero-home__grid line-section"
    style="--line-pos: 30%; min-height: calc(100svh - var(--header-height)); align-items: stretch;"
  >
    <!-- Left zone: Identity statement -->
    <div
      class="hero-home__copy"
      style="display: flex; flex-direction: column; justify-content: flex-end; padding: clamp(40px, 6vw, 80px) 40px clamp(48px, 6vw, 80px) 0;"
    >
      <div data-hero-item style="opacity: 0; transform: translateY(24px);">
        <img
          src="/assets/branding/apdw-ai-logo.png"
          alt="Archi-Prisma Design Works"
          class="hero-home__logo"
          style="height: 28px; width: auto; display: block;"
          width="236"
          height="28"
        />
      </div>

      <div
        data-hero-item
        style="opacity: 0; transform: translateY(24px); margin-top: 48px;"
      >
        <p style="font-family: var(--font-display); font-size: var(--text-nav); font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-ink-muted); margin: 0 0 6px;">
          Est. 2024
        </p>
        <p style="font-family: var(--font-display); font-size: var(--text-nav); font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-ink-muted); margin: 0;">
          Tokyo / London
        </p>
      </div>

      <div
        data-hero-item
        style="opacity: 0; transform: translateY(24px); margin-top: 40px;"
      >
        <h1 style="font-family: var(--font-display); font-size: var(--text-section); font-weight: 700; color: var(--color-ink); line-height: 1.15; margin: 0 0 20px; letter-spacing: -0.02em;">
          Architecture<br />× Software
        </h1>
        <p style="font-family: var(--font-jp); font-size: var(--text-body); line-height: 1.8; color: var(--color-ink-muted); margin: 0; max-width: 28ch;">
          都市開発からAI開発まで。設計・運営・テクノロジーで、建築のすべてを手がける。
        </p>
      </div>

      <div
        data-hero-item
        style="opacity: 0; margin-top: 48px; height: 1px; background-color: var(--color-rule);"
      ></div>
    </div>

    <!-- Dividing line (structural spacer) -->
    <div class="dividing-line" aria-hidden="true"></div>

    <!-- Right zone: Hero image + WebGL overlay -->
    <div
      id="hero-image-container"
      class="hero-home__media"
      data-webgl-src="/assets/curated/masterplan-aerial.jpg"
      style="position: relative; overflow: hidden; min-height: 320px;"
    >
      <div
        data-hero-image
        style="clip-path: inset(0 100% 0 0); height: 100%; width: 100%;"
      >
        <img
          src="/assets/curated/masterplan-aerial.jpg"
          alt="The Super Yacht Club — Archi-Prisma Design Works"
          style="width: 100%; height: 100%; object-fit: cover; object-position: center; display: block;"
          loading="eager"
          fetchpriority="high"
          width="1920"
          height="823"
        />
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { initWebGLHero, revealHero, destroyWebGLHero } from '../lib/webgl-hero';

  function animateHero() {
    const loaderShown = !sessionStorage.getItem('apdw-loader-shown-before');
    if (!sessionStorage.getItem('apdw-loader-shown-before') && sessionStorage.getItem('apdw-loader-shown')) {
      sessionStorage.setItem('apdw-loader-shown-before', '1');
    }
    const delay = loaderShown ? 2.0 : 0.2;

    // Init WebGL lens effect (desktop only — mobile gets static image)
    const heroContainer = document.getElementById('hero-image-container');
    if (heroContainer) {
      initWebGLHero(heroContainer);
    }

    const tl = gsap.timeline({
      defaults: { ease: 'power3.out' },
      delay,
    });

    // Clip-path reveal + WebGL blur→focus
    tl.to('[data-hero-image]', {
      clipPath: 'inset(0 0% 0 0)',
      duration: 1.4,
      ease: 'power4.inOut',
      onStart: () => revealHero(),
    });

    // Stagger in text elements
    tl.to('[data-hero-item]', {
      opacity: 1,
      y: 0,
      duration: 0.9,
      stagger: 0.15,
    }, '-=0.8');
  }

  document.addEventListener('DOMContentLoaded', animateHero);

  document.addEventListener('astro:before-swap', () => destroyWebGLHero());
  document.addEventListener('astro:after-swap', animateHero);
</script>

<style>
  @media (max-width: 767px) {
    .hero-home {
      min-height: auto !important;
      padding-top: var(--header-height) !important;
    }

    .hero-home__grid {
      min-height: auto !important;
      gap: 0;
    }

    .hero-home__copy {
      padding: 2rem 0 1.5rem !important;
      gap: 0;
    }

    .hero-home__logo {
      display: none !important;
    }

    .hero-home__copy [data-hero-item]:nth-child(2) {
      margin-top: 1.5rem !important;
    }

    .hero-home__copy [data-hero-item]:nth-child(3) {
      margin-top: 1.25rem !important;
    }

    .hero-home__copy [data-hero-item]:last-child {
      margin-top: 1.5rem !important;
    }

    .hero-home__copy h1 {
      font-size: clamp(2.45rem, 12vw, 3.5rem) !important;
      line-height: 0.95 !important;
      margin-bottom: 0.9rem !important;
    }

    .hero-home [data-hero-item] {
      opacity: 1 !important;
      transform: none !important;
    }

    .hero-home [data-hero-image] {
      clip-path: inset(0 0 0 0) !important;
    }

    .hero-home__copy p {
      max-width: none !important;
    }

    .hero-home__media {
      min-height: 38svh !important;
      margin-left: calc(var(--content-padding-x) * -1);
      margin-right: calc(var(--content-padding-x) * -1);
    }
  }
</style>
