---
/**
 * BrandBridge — Task 11
 * id="bridge". The "prism moment" — 50/50 split light/dark.
 * Desktop: horizontal split. Left light, right dark.
 * Mobile: vertical (stacked), light on top, dark on bottom.
 */
---

<section id="bridge" aria-label="建築も、ソフトウェアも。">
  <!--
    We build this without the .line-section grid because it requires
    a full-bleed 50/50 color split. We fake the 1px line in the middle.
  -->
  <div
    style="
      display: flex;
      flex-direction: column;
      min-height: 50vh;
    "
    class="bridge-inner"
  >
    <!-- Light half -->
    <div
      class="bridge-half bridge-light"
      style="
        background-color: var(--color-surface);
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding: clamp(40px, 6vw, 80px) var(--content-padding-x);
        position: relative;
      "
    >
      <p
        class="bridge-text"
        style="
          font-family: var(--font-jp);
          font-size: var(--text-section);
          font-weight: 700;
          line-height: 1.2;
          color: var(--color-ink);
          margin: 0;
          text-align: right;
        "
      >
        建築も、
      </p>
    </div>

    <!-- The 1px dividing line (horizontal on mobile, vertical on desktop) -->
    <div
      class="bridge-rule"
      aria-hidden="true"
      style="
        background: linear-gradient(
          to right,
          var(--color-accent-decorative),
          var(--color-accent-dark)
        );
        flex-shrink: 0;
      "
    ></div>

    <!-- Dark half -->
    <div
      class="bridge-half bridge-dark"
      style="
        background-color: var(--color-surface-dark);
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: flex-start;
        padding: clamp(40px, 6vw, 80px) var(--content-padding-x);
        position: relative;
      "
    >
      <p
        class="bridge-text"
        style="
          font-family: var(--font-jp);
          font-size: var(--text-section);
          font-weight: 700;
          line-height: 1.2;
          color: var(--color-ink-dark);
          margin: 0;
          text-align: left;
        "
      >
        ソフトウェアも。
      </p>
    </div>
  </div>
</section>

<style>
  /* Mobile: vertical stack (column) — light top, dark bottom, h-rule between */
  .bridge-inner {
    flex-direction: column;
    min-height: 50vh;
  }

  .bridge-rule {
    width: 100%;
    height: 1px;
  }

  /* Desktop: horizontal split side-by-side */
  @media (min-width: 768px) {
    .bridge-inner {
      flex-direction: row;
      min-height: 50vh;
    }

    .bridge-half {
      flex: 1;
    }

    .bridge-light {
      justify-content: flex-end;
      padding-right: clamp(40px, 5vw, 80px);
    }

    .bridge-dark {
      justify-content: flex-start;
      padding-left: clamp(40px, 5vw, 80px);
    }

    /* Vertical rule between halves */
    .bridge-rule {
      width: 1px;
      height: auto;
      background: linear-gradient(
        to bottom,
        var(--color-accent-decorative),
        var(--color-accent-dark)
      );
    }
  }
</style>
