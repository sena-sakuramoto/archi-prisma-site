---
/**
 * ContactForm — Inquiry form with validation, success/error states.
 * Props: { inquiryTypes: string[] }
 */
interface Props {
  inquiryTypes: string[];
}

const { inquiryTypes } = Astro.props;
---

<div class="contact-form-wrap reveal" style="--delay: 0.15s">
  <h2 class="contact-form__heading">お問い合わせ</h2>

  <!-- Success message (hidden by default) -->
  <div id="form-success" class="contact-form__status contact-form__status--success" hidden aria-live="polite">
    <p class="contact-form__status-title">送信完了</p>
    <p class="contact-form__status-text">お問い合わせありがとうございます。<br />2営業日以内にご返信いたします。</p>
  </div>

  <!-- Error message (hidden by default) -->
  <div id="form-error" class="contact-form__status contact-form__status--error" hidden aria-live="polite">
    <p class="contact-form__status-title">送信エラー</p>
    <p class="contact-form__status-text">送信に失敗しました。もう一度お試しください。</p>
    <button type="button" id="form-retry" class="contact-form__retry">再試行 →</button>
  </div>

  <!-- Error summary for accessibility (hidden by default) -->
  <div id="form-errors-summary" role="alert" aria-live="assertive" tabindex="-1" hidden></div>

  <form id="contact-form" class="contact-form" novalidate>
    <div class="contact-form__field">
      <label for="inquiry-type" class="contact-form__label">ご相談内容</label>
      <select
        id="inquiry-type"
        name="type"
        class="contact-form__select"
        required
        aria-describedby="error-type"
      >
        <option value="" disabled selected>選択してください</option>
        {inquiryTypes.map((t) => (
          <option value={t}>{t}</option>
        ))}
      </select>
      <span id="error-type" class="contact-form__error" role="alert" hidden></span>
    </div>
    <div class="contact-form__field">
      <label for="inquiry-name" class="contact-form__label">お名前</label>
      <input
        id="inquiry-name"
        name="name"
        type="text"
        class="contact-form__input"
        required
        placeholder="山田 太郎"
        autocomplete="name"
        aria-describedby="error-name"
      />
      <span id="error-name" class="contact-form__error" role="alert" hidden></span>
    </div>
    <div class="contact-form__field">
      <label for="inquiry-company" class="contact-form__label">会社名 <span class="contact-form__optional">任意</span></label>
      <input
        id="inquiry-company"
        name="company"
        type="text"
        class="contact-form__input"
        placeholder="株式会社〇〇"
        autocomplete="organization"
      />
    </div>
    <div class="contact-form__field">
      <label for="inquiry-email" class="contact-form__label">メールアドレス</label>
      <input
        id="inquiry-email"
        name="email"
        type="email"
        class="contact-form__input"
        required
        placeholder="info@example.com"
        autocomplete="email"
        aria-describedby="error-email"
      />
      <span id="error-email" class="contact-form__error" role="alert" hidden></span>
    </div>
    <div class="contact-form__field">
      <label for="inquiry-message" class="contact-form__label">メッセージ</label>
      <textarea
        id="inquiry-message"
        name="message"
        class="contact-form__textarea"
        rows="5"
        required
        placeholder="ご相談内容をお書きください"
        aria-describedby="error-message"
      ></textarea>
      <span id="error-message" class="contact-form__error" role="alert" hidden></span>
    </div>
    <div class="contact-form__field contact-form__consent">
      <label class="contact-form__consent-label">
        <input
          type="checkbox"
          name="privacy"
          id="inquiry-privacy"
          required
          class="contact-form__checkbox"
          aria-describedby="error-privacy"
        />
        <span class="contact-form__consent-text">個人情報の取り扱いに同意する</span>
      </label>
      <span id="error-privacy" class="contact-form__error" role="alert" hidden></span>
    </div>
    <button type="submit" id="form-submit" class="contact-form__submit">
      <span class="contact-form__submit-text">送信する →</span>
      <span class="contact-form__submit-loading" hidden>送信中...</span>
    </button>
    <p id="form-note" class="contact-form__note">
      送信ボタンを押すとメールアプリが開きます
    </p>
  </form>
</div>

<style>
  .contact-form-wrap {
    padding: clamp(2rem, 4vw, 3rem);
    background: var(--color-surface);
  }
  .contact-form__heading {
    font-family: var(--font-display); font-size: 1.3rem;
    font-weight: 700; margin-bottom: 1.5rem;
  }
  .contact-form__field { margin-bottom: 1.25rem; }
  .contact-form__label {
    font-family: var(--font-jp); font-size: var(--text-caption);
    font-weight: 500; color: var(--color-ink);
    display: block; margin-bottom: 0.4rem;
  }
  .contact-form__optional {
    font-weight: 400; color: var(--color-ink-muted); font-size: 0.8rem;
  }
  .contact-form__select,
  .contact-form__input,
  .contact-form__textarea {
    width: 100%; font-family: var(--font-jp); font-size: var(--text-body);
    padding: 0.7rem 0.9rem; border: 1px solid var(--color-rule);
    border-radius: 3px; background: white; color: var(--color-ink);
    transition: border-color 0.2s var(--ease);
    -webkit-appearance: none; appearance: none;
  }
  .contact-form__select:focus,
  .contact-form__input:focus,
  .contact-form__textarea:focus {
    border-color: var(--color-accent); outline: none;
  }
  .contact-form__select:focus-visible,
  .contact-form__input:focus-visible,
  .contact-form__textarea:focus-visible {
    border-color: var(--color-accent);
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
  }
  .contact-form__textarea { resize: vertical; min-height: 100px; }

  /* ─── Privacy consent ─── */
  .contact-form__consent {
    margin-bottom: 1.5rem;
  }
  .contact-form__consent-label {
    display: flex; align-items: flex-start; gap: 0.5rem;
    cursor: pointer;
  }
  .contact-form__checkbox {
    width: 16px; height: 16px; margin-top: 2px;
    accent-color: var(--color-accent);
    flex-shrink: 0;
  }
  .contact-form__consent-text {
    font-family: var(--font-jp); font-size: 0.8rem;
    color: var(--color-ink-muted); line-height: 1.5;
  }

  /* ─── Submit ─── */
  .contact-form__submit {
    font-family: var(--font-display); font-size: 0.85rem;
    font-weight: 600; letter-spacing: 0.08em;
    padding: 0.85rem 2.5rem; border-radius: 3px; border: none;
    background: var(--color-ink); color: var(--color-surface);
    cursor: pointer; transition: background 0.25s var(--ease);
    width: 100%;
  }
  .contact-form__submit:hover { background: var(--color-accent); }
  .contact-form__submit:focus-visible {
    background: var(--color-accent);
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .contact-form__submit:disabled {
    opacity: 0.6; cursor: not-allowed;
  }
  .contact-form__note {
    font-family: var(--font-jp); font-size: 0.8rem;
    color: var(--color-ink-muted); text-align: center;
    margin-top: 0.75rem;
  }
  .contact-form__error {
    font-family: var(--font-jp); font-size: 0.8rem;
    color: #c44; display: block; margin-top: 0.3rem;
  }
  .contact-form__error[hidden] {
    display: none;
  }
  :global(.is-invalid) {
    border-color: #c44 !important;
  }

  /* ─── Error summary ─── */
  #form-errors-summary {
    font-family: var(--font-jp); font-size: 0.85rem;
    color: #8b2525; background: #fdf2f2;
    border: 1px solid #e5c4c4; border-radius: 3px;
    padding: 0.75rem 1rem; margin-bottom: 1rem;
    line-height: 1.6;
  }
  #form-errors-summary[hidden] {
    display: none;
  }

  /* ─── Status messages ─── */
  .contact-form__status {
    padding: 2rem; border-radius: 3px; text-align: center;
  }
  .contact-form__status[hidden] {
    display: none;
  }
  .contact-form__status--success {
    background: #f0f7f0; border: 1px solid #c4dcc4;
  }
  .contact-form__status--error {
    background: #fdf2f2; border: 1px solid #e5c4c4;
  }
  .contact-form__status-title {
    font-family: var(--font-display); font-size: 1.1rem;
    font-weight: 700; margin-bottom: 0.5rem;
  }
  .contact-form__status--success .contact-form__status-title {
    color: #2d5a2d;
  }
  .contact-form__status--error .contact-form__status-title {
    color: #8b2525;
  }
  .contact-form__status-text {
    font-family: var(--font-jp); font-size: var(--text-caption);
    color: var(--color-ink-muted); line-height: 1.7;
  }
  .contact-form__retry {
    font-family: var(--font-display); font-size: 0.8rem;
    font-weight: 600; letter-spacing: 0.06em;
    padding: 0.6rem 1.5rem; border-radius: 3px; border: none;
    background: var(--color-ink); color: var(--color-surface);
    cursor: pointer; margin-top: 1rem;
    transition: background 0.25s var(--ease);
  }
  .contact-form__retry:hover { background: var(--color-accent); }
  .contact-form__retry:focus-visible {
    background: var(--color-accent);
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>
