---
// Coming Soon — ARCHI PRISMA
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ARCHI PRISMA | Coming Soon</title>
    <meta name="description" content="Archi-Prisma Design Works — Architecture × Software. Tokyo / London." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=Outfit:wght@200;300&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html, body {
        height: 100%;
        background: #0A0A0A;
        color: #F0EEEB;
        font-family: 'Syne', sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      body {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 2rem;
        text-align: center;
      }

      .wordmark {
        font-family: 'Syne', sans-serif;
        font-weight: 800;
        font-size: clamp(2.2rem, 9vw, 5.5rem);
        letter-spacing: 0.14em;
        color: #F0EEEB;
        line-height: 1;
        margin-bottom: 0.5em;
      }

      .tagline {
        font-family: 'Outfit', sans-serif;
        font-weight: 200;
        font-size: clamp(0.65rem, 1.8vw, 0.875rem);
        letter-spacing: 0.35em;
        text-transform: uppercase;
        color: #555;
        margin-bottom: 4.5rem;
      }

      .rule {
        width: 1px;
        height: 56px;
        background: linear-gradient(to bottom, transparent, #3A3A3A, transparent);
        margin: 0 auto 3.5rem;
      }

      .status-en {
        font-family: 'Outfit', sans-serif;
        font-weight: 300;
        font-size: clamp(0.8rem, 2.5vw, 1.05rem);
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: #C8C4C0;
        margin-bottom: 0.6rem;
      }

      .status-ja {
        font-family: 'Outfit', sans-serif;
        font-weight: 200;
        font-size: clamp(0.7rem, 2vw, 0.85rem);
        letter-spacing: 0.2em;
        color: #555;
      }

      footer {
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        font-family: 'Outfit', sans-serif;
        font-weight: 200;
        font-size: 0.65rem;
        letter-spacing: 0.22em;
        color: #333;
        white-space: nowrap;
      }
    </style>
  </head>
  <body>
    <p class="wordmark">ARCHI PRISMA</p>
    <p class="tagline">Architecture &times; Software &mdash; Tokyo / London</p>
    <div class="rule"></div>
    <p class="status-en">Coming Soon</p>
    <p class="status-ja">準備中</p>
    <footer>&copy; 2026 Archi-Prisma Design Works</footer>
  </body>
</html>
