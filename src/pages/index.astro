---
import Layout from '../layouts/Layout.astro';
import PageLoader from '../components/PageLoader.astro';
import Header from '../components/Header.astro';
import DividingLine from '../components/DividingLine.astro';
import Hero from '../components/Hero.astro';
import WorksHighlight from '../components/WorksHighlight.astro';
import BrandBridge from '../components/BrandBridge.astro';
import Products from '../components/Products.astro';
import Team from '../components/Team.astro';
import CompanyInfo from '../components/CompanyInfo.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  description="建築設計とソフトウェア開発の二軸で未来を切り拓く設計事務所 Archi-Prisma Design Works。都市開発・ホテル・商業施設の実績多数。東京/ロンドン拠点。"
  preloadImages={['/assets/curated/masterplan-aerial.jpg']}
>
  <PageLoader />
  <Header />
  <DividingLine />
  <main>
    <Hero />
    <WorksHighlight />
    <BrandBridge />
    <Products />

    <!-- Hook: AI事業への導線 — "The Slit Opens" -->
    <section id="hook-manifesto" class="hook dark-space">
      <!-- Image revealed through expanding slit -->
      <div class="hook__img-wrap img-vignette img-grain">
        <img
          src="/assets/generated/hook-manifesto.jpg"
          alt=""
          aria-hidden="true"
          loading="lazy"
          class="hook__img hook-slit-img img-graded"
          width="1920"
          height="823"
        />
      </div>
      <!-- Golden center line (visible before slit opens) -->
      <div class="hook__center-line hook-center-line"></div>
      <!-- Text content -->
      <div class="hook__content">
        <p class="reveal hook__lead hook-line-1">
          建築を知らない人間が AI を持っても、<br />現場では何も変えられない。
        </p>
        <p class="reveal hook__headline hook-line-2">
          経験を持つ人間が<br />AI を手にしたとき、<br />革命が起きる。
        </p>
        <a href="/ai/" class="hook__cta link-animated">
          AI × 建築事業 →
        </a>
      </div>
    </section>

    <Team />
    <CompanyInfo />
  </main>
  <Footer />

  <script>
    import { initLineSystem, destroyLineSystem } from '../lib/line-system';
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import Lenis from 'lenis';

    gsap.registerPlugin(ScrollTrigger);

    let lenis: Lenis | null = null;

    function init() {
      // Clean up previous instances (View Transitions re-entry)
      if (lenis) { lenis.destroy(); lenis = null; }
      destroyLineSystem();

      // Smooth scroll
      lenis = new Lenis({
        duration: 1.2,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      });

      // Connect Lenis ↔ GSAP ScrollTrigger
      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add((time) => {
        lenis!.raf(time * 1000);
      });
      gsap.ticker.lagSmoothing(0);

      // Line system (desktop only)
      if (window.matchMedia('(min-width: 768px)').matches) {
        initLineSystem();
      }

      // Header space awareness
      const header = document.getElementById('site-header');
      const darkSections = document.querySelectorAll('.dark-space');
      if (header && darkSections.length > 0) {
        const observer = new IntersectionObserver(
          (entries) => {
            const isInDark = entries.some(e => e.isIntersecting);
            header.setAttribute('data-space', isInDark ? 'dark' : 'light');
          },
          { rootMargin: '-64px 0px -90% 0px' }
        );
        darkSections.forEach(el => observer.observe(el));
      }

      // Hook slit reveal (desktop)
      if (window.matchMedia('(min-width: 768px)').matches) {
        const hookImg = document.querySelector('.hook-slit-img') as HTMLElement;
        const hookLine = document.querySelector('.hook-center-line') as HTMLElement;
        if (hookImg && hookLine) {
          gsap.to(hookImg, {
            clipPath: 'inset(0 0% 0 0%)',
            ease: 'power2.out',
            scrollTrigger: {
              trigger: '#hook-manifesto',
              start: 'top 70%',
              end: 'center center',
              scrub: 0.8,
            },
          });
          gsap.to(hookLine, {
            opacity: 0,
            scrollTrigger: {
              trigger: '#hook-manifesto',
              start: 'top 50%',
              end: 'center center',
              scrub: 0.5,
            },
          });
        }
      } else {
        // Mobile: show image immediately
        const hookImg = document.querySelector('.hook-slit-img') as HTMLElement;
        if (hookImg) hookImg.style.clipPath = 'inset(0 15% 0 15%)';
      }

      // Scroll reveals
      document.querySelectorAll('.reveal').forEach(el => {
        const observer = new IntersectionObserver(
          ([entry]) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.disconnect();
            }
          },
          { threshold: 0.1 }
        );
        observer.observe(el);
      });
    }

    // Initial load + re-init on View Transition swap (previous listener auto-aborted)
    import { registerPageInit } from '../lib/scroll-engine';
    registerPageInit(init);
  </script>

  <style>
    /* ─── Hook Manifesto ─── */
    .hook {
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hook__img-wrap {
      position: absolute;
      inset: 0;
    }
    .hook__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      clip-path: inset(0 49% 0 49%);
    }
    .hook__center-line {
      position: absolute;
      left: 50%;
      top: 10%;
      bottom: 10%;
      width: 1px;
      transform: translateX(-50%);
      background: linear-gradient(to bottom, transparent, var(--color-accent-dark), transparent);
      z-index: 2;
      opacity: 1;
    }
    .hook__content {
      position: relative;
      z-index: 3;
      max-width: 800px;
      padding: 0 var(--content-padding-x);
      text-align: center;
    }
    .hook__lead {
      font-family: var(--font-jp);
      font-size: clamp(1rem, 2.2vw, 1.4rem);
      font-weight: 400;
      color: rgba(240, 238, 235, 0.75);
      line-height: 2.2;
      margin-bottom: 3rem;
      letter-spacing: 0.05em;
    }
    .hook__headline {
      font-family: var(--font-jp);
      font-size: clamp(1.4rem, 3.5vw, 2.5rem);
      font-weight: 700;
      color: var(--color-ink-dark);
      line-height: 1.6;
      margin-bottom: 4rem;
      letter-spacing: -0.01em;
    }
    .hook__cta {
      font-family: var(--font-display);
      font-size: 0.9rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--color-accent-dark);
      text-decoration: none;
    }
  </style>
</Layout>
