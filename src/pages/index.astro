---
const contactEmail = 'contact@archi-prisma.co.jp';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Archi-Prisma | Temporary Site</title>
    <meta name="description" content="Archi-Prisma temporary site." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Noto+Sans+JP:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        color-scheme: light;
        --paper: #ebe5da;
        --ink: #171512;
        --muted: rgba(23, 21, 18, 0.58);
        --rule: rgba(23, 21, 18, 0.14);
        --accent: #6f665f;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
        background:
          linear-gradient(to right, transparent 0, transparent calc(8.333% - 1px), rgba(23, 21, 18, 0.035) calc(8.333% - 1px), rgba(23, 21, 18, 0.035) 8.333%),
          linear-gradient(180deg, #f1ece2 0%, var(--paper) 100%);
        background-size: 12% 100%, 100% 100%;
        color: var(--ink);
        font-family: 'Noto Sans JP', sans-serif;
      }

      body {
        padding: 22px;
      }

      .frame {
        min-height: calc(100vh - 44px);
        border: 1px solid var(--rule);
        padding: 32px;
        position: relative;
      }

      .frame::before,
      .frame::after {
        content: '';
        position: absolute;
        inset: 14px;
        border: 1px solid rgba(23, 21, 18, 0.06);
        pointer-events: none;
      }

      .shell {
        min-height: calc(100vh - 108px);
        display: grid;
        grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
        gap: 56px;
        align-items: end;
      }

      .masthead {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 24px;
        margin-bottom: 88px;
      }

      .brand {
        width: min(360px, 100%);
      }

      .brand img {
        display: block;
        width: 100%;
        height: auto;
      }

      .meta {
        padding-top: 8px;
        color: var(--muted);
        font-size: 11px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .eyebrow {
        margin: 0 0 18px;
        color: var(--accent);
        font-size: 12px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(4rem, 8.2vw, 7.4rem);
        font-weight: 500;
        line-height: 0.92;
        letter-spacing: -0.04em;
      }

      .lead {
        max-width: 38rem;
        margin: 28px 0 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 2;
      }

      .aside {
        align-self: stretch;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
      }

      .card {
        margin-left: auto;
        width: min(100%, 360px);
        padding-top: 18px;
        border-top: 1px solid var(--ink);
      }

      .card-label {
        margin: 0 0 14px;
        color: var(--muted);
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .card-title {
        margin: 0 0 18px;
        font-family: 'Cormorant Garamond', serif;
        font-size: 32px;
        line-height: 1;
      }

      .contact-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 22px;
        border: 1px solid var(--ink);
        color: var(--ink);
        text-decoration: none;
        transition:
          background-color 180ms ease,
          color 180ms ease,
          transform 180ms ease;
      }

      .contact-link:hover {
        background: var(--ink);
        color: var(--paper);
        transform: translateY(-1px);
      }

      .mail {
        display: inline-block;
        margin-top: 18px;
        color: var(--ink);
        text-decoration: none;
      }

      .note {
        margin: 10px 0 0;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.8;
      }

      .footer {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        margin-top: 48px;
        padding-top: 18px;
        border-top: 1px solid var(--rule);
        color: var(--muted);
        font-size: 11px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      @media (max-width: 980px) {
        .shell {
          grid-template-columns: 1fr;
          gap: 40px;
          align-items: start;
        }

        .masthead {
          margin-bottom: 56px;
          flex-direction: column;
        }

        .aside {
          align-self: auto;
        }

        .card {
          margin-left: 0;
        }

        .footer {
          flex-direction: column;
        }
      }

      @media (max-width: 720px) {
        body {
          padding: 12px;
        }

        .frame {
          min-height: calc(100vh - 24px);
          padding: 22px;
        }

        .frame::before,
        .frame::after {
          display: none;
        }

        .shell {
          min-height: auto;
        }

        h1 {
          font-size: clamp(3.2rem, 16vw, 5rem);
        }

        .contact-link {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <main class="frame">
      <section class="shell">
        <div>
          <header class="masthead">
            <div class="brand">
              <img src="/assets/branding/apdw-logo.png" alt="Archi-Prisma Design Works" />
            </div>
            <div class="meta">Tokyo / Temporary Site</div>
          </header>

          <p class="eyebrow">Under Revision</p>
          <h1>
            Web site
            <br />
            in revision
          </h1>
          <p class="lead">
            ただいまホームページを再構成しています。
            <br />
            プロジェクトのご相談、お問い合わせは引き続き受け付けています。
          </p>
        </div>

        <aside class="aside">
          <div class="card">
            <p class="card-label">Contact</p>
            <h2 class="card-title">Open for inquiries.</h2>
            <a class="contact-link" href={`mailto:${contactEmail}`}>お問い合わせ</a>
            <a class="mail" href={`mailto:${contactEmail}`}>{contactEmail}</a>
            <p class="note">Design consultation / collaboration / press inquiries</p>
          </div>
        </aside>
      </section>

      <footer class="footer">
        <span>Archi-Prisma Design Works</span>
        <span>Architecture / Planning / AI</span>
      </footer>
    </main>
  </body>
</html>
