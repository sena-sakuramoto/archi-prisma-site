---
import Layout from '../layouts/Layout.astro';
---
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ARCHI PRISMA | Coming Soon</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #0a0a0a; color: #fff; font-family: 'Syne', 'Noto Sans JP', sans-serif; }
    .container { text-align: center; padding: 2rem; }
    h1 { font-size: clamp(2rem, 5vw, 4rem); letter-spacing: 0.3em; margin-bottom: 1rem; font-weight: 300; }
    .line { width: 60px; height: 1px; background: #fff; margin: 2rem auto; opacity: 0.4; }
    p { font-size: 1rem; letter-spacing: 0.15em; opacity: 0.6; }
    .sub { font-size: 0.85rem; margin-top: 0.5rem; }
  </style>
</head>
<body>
  <div class="container">
    <h1>ARCHI PRISMA</h1>
    <div class="line"></div>
    <p>Coming Soon</p>
    <p class="sub">準備中</p>
  </div>
</body>
</html>
