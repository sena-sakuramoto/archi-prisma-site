---
const contactEmail = 'contact@archi-prisma.co.jp';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Archi-Prisma | Renewal in Progress</title>
    <meta
      name="description"
      content="Archi-Prisma のホームページは現在改装中です。お問い合わせはメールにて受け付けています。"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Noto+Sans+JP:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        color-scheme: dark;
        --bg: #0a0a0a;
        --text: #f5f5f2;
        --muted: rgba(245, 245, 242, 0.66);
        --line: rgba(245, 245, 242, 0.12);
        --panel: #f2efe8;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
        background:
          radial-gradient(circle at top, rgba(255, 255, 255, 0.06), transparent 30%),
          linear-gradient(180deg, #050505 0%, #0a0a0a 100%);
        color: var(--text);
        font-family: 'Inter', 'Noto Sans JP', sans-serif;
      }

      body {
        padding: 24px;
      }

      main {
        min-height: calc(100vh - 48px);
        display: grid;
        place-items: center;
      }

      .wrap {
        width: min(100%, 680px);
      }

      .logo {
        width: fit-content;
        max-width: 100%;
        margin-bottom: 40px;
        padding: 18px 22px;
        border-radius: 24px;
        background: var(--panel);
      }

      .logo img {
        display: block;
        width: min(100%, 420px);
        height: auto;
      }

      h1 {
        margin: 0;
        font-size: clamp(3rem, 10vw, 5.8rem);
        line-height: 0.96;
        letter-spacing: -0.06em;
      }

      p {
        margin: 0;
      }

      .lead {
        margin-top: 28px;
        color: var(--muted);
        font-size: clamp(1rem, 1.8vw, 1.08rem);
        line-height: 1.9;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 34px;
      }

      .button,
      .mail {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 50px;
        padding: 0 24px;
        border-radius: 999px;
        text-decoration: none;
        transition:
          transform 180ms ease,
          background-color 180ms ease,
          border-color 180ms ease,
          color 180ms ease;
      }

      .button {
        background: #f5f5f2;
        color: #0a0a0a;
        font-weight: 600;
      }

      .button:hover {
        transform: translateY(-1px);
      }

      .mail {
        border: 1px solid var(--line);
        color: var(--text);
      }

      .mail:hover {
        border-color: rgba(245, 245, 242, 0.28);
        transform: translateY(-1px);
      }

      .note {
        margin-top: 14px;
        color: rgba(245, 245, 242, 0.45);
        font-size: 14px;
        line-height: 1.8;
      }

      @media (max-width: 720px) {
        body {
          padding: 20px;
        }

        main {
          min-height: calc(100vh - 40px);
        }

        .logo {
          margin-bottom: 32px;
          padding: 16px 18px;
        }

        .actions {
          flex-direction: column;
          align-items: stretch;
        }

        .button,
        .mail {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <section class="wrap">
        <div class="logo">
          <img src="/assets/branding/apdw-logotype.png" alt="Archi-Prisma" />
        </div>

        <h1>
          ただいま
          <br />
          サイトを改装中です。
        </h1>

        <p class="lead">
          新しいホームページを準備しています。
          <br />
          公開まで、もう少しだけお待ちください。
        </p>

        <div class="actions">
          <a class="button" href={`mailto:${contactEmail}`}>お問い合わせ</a>
          <a class="mail" href={`mailto:${contactEmail}`}>{contactEmail}</a>
        </div>

        <p class="note">ご相談やご連絡はメールで受け付けています。</p>
      </section>
    </main>
  </body>
</html>
