---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { loadTeam } from '../../lib/content';

const { core, advisory_legacy, collaborators } = loadTeam();
const [ceo, ...otherMembers] = core;

const services = [
  '建築・土木設計監理',
  '建築関連の事業計画・コンサルティング',
  '都市開発・建設・飲食等プロデュース',
  '建築パース・CG制作',
  '店舗・オフィス・住宅等インテリアデザイン',
  'コンピューターソフトウェアの企画・開発',
  'コンピューター操作指導',
  '家具・食器・照明等プロダクトデザイン',
  'ロゴマーク・サイン等グラフィックデザイン',
  'ホテル・宿泊施設の経営・管理',
];
---

<Layout
  title="About | Archi-Prisma Design Works"
  description="Archi-Prisma Design Worksについて。会社概要、サービス、グローバルネットワーク、チームメンバー。"
>
  <Header />

  <main style="padding-top: 64px;">
    <!-- About heading + description -->
    <section
      style="max-width: var(--max-width); margin: 0 auto; padding: clamp(48px, 7vw, 96px) var(--content-padding-x) clamp(48px, 7vw, 96px); border-bottom: 1px solid var(--color-rule);"
    >
      <p
        style="font-family: var(--font-display); font-size: var(--text-caption); font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-ink-muted); margin: 0 0 clamp(20px, 3vw, 32px);"
      >
        About
      </p>
      <h1
        style="font-family: var(--font-display); font-size: var(--text-section); font-weight: 700; letter-spacing: -0.03em; line-height: 1; color: var(--color-ink); margin: 0 0 clamp(32px, 5vw, 56px);"
      >
        MOVE HEARTS.<br />
        <span
          style="font-size: clamp(1.4rem, 2.5vw, 2.2rem); color: var(--color-ink-muted);"
        >心を動かせ</span>
      </h1>

      <div
        style="display: grid; gap: clamp(20px, 3vw, 32px);"
        class="about-body-grid"
      >
        <p
          style="font-family: var(--font-jp); font-size: var(--text-body); line-height: 2; color: var(--color-ink); margin: 0; max-width: 64ch;"
        >
          AI × 建築で、人生と街に "わくわく" の火を灯す。
        </p>
        <p
          style="font-family: var(--font-jp); font-size: var(--text-body); line-height: 2; color: var(--color-ink-muted); margin: 0; max-width: 64ch;"
        >
          Archi-Prisma Design Works 株式会社は、2001年に英国で設立された Archi-Prisma Ltd. London、
          および日本法人として設立されたアーキプリズマインターナショナル株式会社の実績と経験を継承し、
          2024年に東京・品川で誕生しました。AIとArchicadの統合、国際的デザイナーとの強固なパートナー体制を軸に、
          都市開発・商業施設・ホテル・住宅までを幅広く手掛けます。
        </p>
        <p
          style="font-family: var(--font-jp); font-size: var(--text-body); line-height: 2; color: var(--color-ink-muted); margin: 0; max-width: 64ch;"
        >
          代表・櫻本聖成は、最年少でArchicadの代理店契約を締結。
          AI連動のアドオン開発や高精度のビジュアライゼーションで、設計から意思決定までの体験を刷新します。
        </p>
      </div>
    </section>

    <!-- Services -->
    <section
      style="max-width: var(--max-width); margin: 0 auto; padding: clamp(48px, 7vw, 96px) var(--content-padding-x); border-bottom: 1px solid var(--color-rule);"
    >
      <p
        style="font-family: var(--font-display); font-size: var(--text-caption); font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-ink-muted); margin: 0 0 clamp(32px, 4vw, 48px);"
      >
        Services
      </p>
      <ol style="list-style: none; padding: 0; margin: 0;">
        {services.map((service, i) => (
          <li
            style={`
              display: flex;
              align-items: baseline;
              gap: 24px;
              padding: 18px 0;
              border-top: 1px solid var(--color-rule);
              ${i === services.length - 1 ? 'border-bottom: 1px solid var(--color-rule);' : ''}
            `}
          >
            <span
              style="font-family: var(--font-display); font-size: var(--text-caption); font-weight: 600; color: var(--color-ink-muted); min-width: 2ch; flex-shrink: 0;"
            >
              {String(i + 1).padStart(2, '0')}
            </span>
            <span
              style="font-family: var(--font-jp); font-size: var(--text-body); color: var(--color-ink); line-height: 1.6;"
            >
              {service}
            </span>
          </li>
        ))}
      </ol>
    </section>

    <!-- Global Network -->
    <section
      style="max-width: var(--max-width); margin: 0 auto; padding: clamp(48px, 7vw, 96px) var(--content-padding-x); border-bottom: 1px solid var(--color-rule);"
    >
      <p
        style="font-family: var(--font-display); font-size: var(--text-caption); font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-ink-muted); margin: 0 0 clamp(32px, 4vw, 48px);"
      >
        Global Network
      </p>

      <div class="network-grid">
        <div style="border-top: 1px solid var(--color-rule); padding-top: 24px;">
          <p
            style="font-family: var(--font-display); font-size: var(--text-caption); font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-accent); margin: 0 0 12px;"
          >
            Tokyo
          </p>
          <p
            style="font-family: var(--font-jp); font-size: var(--text-body); color: var(--color-ink); margin: 0 0 8px; line-height: 1.7;"
          >
            Archi-Prisma Design Works 株式会社
          </p>
          <p
            style="font-family: var(--font-jp); font-size: var(--text-caption); color: var(--color-ink-muted); margin: 0; line-height: 1.6;"
          >
            〒141-0021<br />
            東京都品川区上大崎2-6-7 SMA白金長者丸301
          </p>
        </div>

        <div style="border-top: 1px solid var(--color-rule); padding-top: 24px;">
          <p
            style="font-family: var(--font-display); font-size: var(--text-caption); font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-accent); margin: 0 0 12px;"
          >
            London
          </p>
          <p
            style="font-family: var(--font-jp); font-size: var(--text-body); color: var(--color-ink); margin: 0 0 8px; line-height: 1.7;"
          >
            Archi-Prisma Ltd. London
          </p>
          <p
            style="font-family: var(--font-jp); font-size: var(--text-caption); color: var(--color-ink-muted); margin: 0; line-height: 1.6;"
          >
            提携拠点 / Associate Office<br />
            Est. 2001 — United Kingdom
          </p>
        </div>
      </div>
    </section>

    <!-- Team -->
    <section
      style="max-width: var(--max-width); margin: 0 auto; padding: clamp(48px, 7vw, 96px) var(--content-padding-x) clamp(64px, 8vw, 120px);"
    >
      <p
        style="font-family: var(--font-display); font-size: var(--text-caption); font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-ink-muted); margin: 0 0 clamp(32px, 4vw, 48px);"
      >
        Team
      </p>

      <!-- CEO -->
      <div
        class="ceo-grid"
        style="border-top: 1px solid var(--color-rule); padding: clamp(32px, 4vw, 56px) 0; margin-bottom: clamp(32px, 4vw, 56px);"
      >
        <div style="max-width: 280px;">
          {ceo.image && (
            <div style="aspect-ratio: 3/4; overflow: hidden; margin-bottom: 20px;">
              <img
                src={ceo.image}
                alt={ceo.name}
                loading="lazy"
                style="width: 100%; height: 100%; object-fit: cover; object-position: top center; display: block;"
              />
            </div>
          )}
          <h2
            style="font-family: var(--font-display); font-size: var(--text-project); font-weight: 700; line-height: 1.1; letter-spacing: -0.02em; color: var(--color-ink); margin: 0 0 8px;"
          >
            {ceo.name}
          </h2>
          <p
            style="font-family: var(--font-display); font-size: var(--text-nav); font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-ink-muted); margin: 0 0 16px;"
          >
            {ceo.role}
          </p>
          {ceo.notes && (
            <p
              style="font-family: var(--font-jp); font-size: var(--text-body); line-height: 1.9; color: var(--color-ink-muted); margin: 0;"
            >
              {ceo.notes}
            </p>
          )}
        </div>
      </div>

      <!-- Other core members -->
      <div
        class="members-grid"
        style="border-top: 1px solid var(--color-rule); padding-top: clamp(32px, 4vw, 48px);"
      >
        {otherMembers.map((member) => (
          <div>
            {member.image && (
              <div style="aspect-ratio: 3/4; overflow: hidden; margin-bottom: 16px; max-width: 200px;">
                <img
                  src={member.image}
                  alt={member.name}
                  loading="lazy"
                  style="width: 100%; height: 100%; object-fit: cover; object-position: top center; display: block; filter: grayscale(100%);"
                />
              </div>
            )}
            <p
              style="font-family: var(--font-display); font-size: var(--text-body); font-weight: 700; color: var(--color-ink); margin: 0 0 4px;"
            >
              {member.name}
            </p>
            <p
              style="font-family: var(--font-display); font-size: var(--text-caption); font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-ink-muted); margin: 0;"
            >
              {member.role}
            </p>
            {member.license && (
              <p
                style="font-family: var(--font-jp); font-size: var(--text-caption); color: var(--color-ink-muted); margin: 6px 0 0; line-height: 1.6;"
              >
                {member.license}
              </p>
            )}
          </div>
        ))}
      </div>

      <!-- International collaborators -->
      {collaborators.length > 0 && (
        <div
          style="border-top: 1px solid var(--color-rule); padding-top: clamp(32px, 4vw, 48px); margin-top: clamp(32px, 4vw, 48px);"
        >
          <p
            style="font-family: var(--font-display); font-size: var(--text-caption); font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-ink-muted); margin: 0 0 24px;"
          >
            International Collaborators
          </p>
          <ul
            style="list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 8px 32px;"
          >
            {collaborators.map((c) => (
              <li>
                <span
                  style="font-family: var(--font-display); font-size: var(--text-body); font-weight: 600; color: var(--color-ink);"
                >
                  {c.name}
                </span>
                <span
                  style="font-family: var(--font-display); font-size: var(--text-caption); color: var(--color-ink-muted); margin-left: 8px;"
                >
                  {c.role}
                </span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Advisory -->
      {advisory_legacy.length > 0 && (
        <div
          style="border-top: 1px solid var(--color-rule); padding-top: clamp(32px, 4vw, 48px); margin-top: clamp(32px, 4vw, 48px);"
        >
          <p
            style="font-family: var(--font-display); font-size: var(--text-caption); font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-ink-muted); margin: 0 0 20px;"
          >
            Advisory &amp; Legacy
          </p>
          <ul
            style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px;"
          >
            {advisory_legacy.map((a) => (
              <li>
                <span
                  style="font-family: var(--font-jp); font-size: var(--text-body); color: var(--color-ink); font-weight: 500;"
                >
                  {a.name}
                </span>
                {a.notes && (
                  <span
                    style="font-family: var(--font-jp); font-size: var(--text-caption); color: var(--color-ink-muted); margin-left: 12px;"
                  >
                    — {a.notes}
                  </span>
                )}
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .network-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media (min-width: 640px) {
    .network-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .members-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 32px 24px;
  }
</style>
