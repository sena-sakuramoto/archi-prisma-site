---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const currentYear = new Date().getFullYear();

const products = [
  {
    id: 'compass',
    name: 'COMPASS',
    tagline: '工程管理',
    description: '建築プロジェクトの全工程をガントチャートで可視化。AI補助で予定立案から進捗追跡まで、現場と設計室をつなぐ。',
    logo: '/assets/products/compass-logo.png',
    screenshot: null,
  },
  {
    id: 'kakome',
    name: 'KAKOME',
    tagline: '写真指示書',
    description: '現場写真から指示書を自動生成。撮って囲むだけで、口頭では伝わらないニュアンスをビジュアルで確実に届ける。',
    logo: '/assets/products/kakome-logo-black.png',
    screenshot: null,
  },
  {
    id: 'kozo',
    name: 'KOZO',
    tagline: '構造計算AI',
    description: 'AIによる構造計算の自動化。法改正にも素早く対応し、設計事務所の負担を根本から減らす。',
    logo: '/assets/products/kozo-logo.png',
    screenshot: null,
  },
  {
    id: 'spotpdf',
    name: 'SpotPDF',
    tagline: 'PDF変換',
    description: '建築図面のスマートPDF変換ツール。図面の品質を保ったまま、高速・高精度で変換・共有できる。',
    logo: '/assets/products/spotpdf-logo.jpg',
    screenshot: null,
  },
  {
    id: 'rakuraku',
    name: '楽々省エネ計算',
    tagline: '省エネ計算',
    description: '省エネ基準適合の計算を簡単に。建築基準法改正への対応も、AIがナビゲートしてスムーズに完了。',
    logo: '/assets/products/rakuraku-logo.png',
    screenshot: null,
  },
  {
    id: 'aicommander',
    name: 'AI Commander',
    tagline: 'AI操作支援',
    description: 'AIがArchicadの操作をサポート。複雑なコマンドも自然言語で操作でき、設計作業の効率を劇的に高める。',
    logo: '/assets/products/aicommander-icon.png',
    screenshot: null,
  },
];
---

<Layout
  title="Products | Archi-Prisma Design Works"
  description="Archi-Prisma Design Worksが開発する建築DXツール群。COMPASS、KAKOME、KOZO、SpotPDFなど、AI建築サークルで全ツール使い放題。"
  darkSpace={true}
>
  <Header />

  <main class="dark-space" style="padding-top: 64px; min-height: 100vh;">
    <!-- Page header -->
    <div
      style="max-width: var(--max-width); margin: 0 auto; padding: clamp(48px, 7vw, 96px) var(--content-padding-x) 0;"
    >
      <div
        style="display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 24px; padding-bottom: clamp(40px, 5vw, 64px); border-bottom: 1px solid rgba(196, 168, 130, 0.2);"
      >
        <!-- Logotype (inverted for dark bg) -->
        <img
          src="/assets/branding/apdw-logotype.png"
          alt="Archi-Prisma Design Works"
          class="invert"
          style="height: 32px; width: auto; display: block;"
        />
        <p
          style="font-family: var(--font-display); font-size: var(--text-nav); font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-ink-muted-dark); margin: 0;"
        >
          Software Products
        </p>
      </div>

      <h1
        style="font-family: var(--font-display); font-size: var(--text-section); font-weight: 700; letter-spacing: -0.03em; line-height: 1; color: var(--color-ink-dark); margin: clamp(40px, 5vw, 64px) 0 0;"
      >
        Products
      </h1>
      <p
        style="font-family: var(--font-jp); font-size: var(--text-body); line-height: 1.9; color: var(--color-ink-muted-dark); max-width: 48ch; margin: clamp(20px, 3vw, 32px) 0 0;"
      >
        AI建築サークルに入れば、すべてのツールが使い放題。
        <br />
        日本の建築業界が直面する課題を、AIとテクノロジーで解決する。
      </p>
    </div>

    <!-- Products list -->
    <div
      style="max-width: var(--max-width); margin: 0 auto; padding: clamp(40px, 5vw, 64px) var(--content-padding-x);"
    >
      {products.map((product, i) => (
        <div
          id={product.id}
          style="border-top: 1px solid rgba(196, 168, 130, 0.2); padding: clamp(40px, 5vw, 64px) 0;"
        >
          <div class="product-row">
            <!-- Left: product info -->
            <div class="product-info">
              <img
                src={product.logo}
                alt={product.name}
                class="invert"
                style="height: 40px; width: auto; display: block; object-fit: contain; object-position: left center; margin-bottom: 20px;"
                loading="lazy"
              />
              <p
                style="font-family: var(--font-display); font-size: var(--text-nav); font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-accent-dark); margin: 0 0 16px;"
              >
                {product.tagline}
              </p>
              <p
                style="font-family: var(--font-jp); font-size: var(--text-body); line-height: 1.9; color: var(--color-ink-muted-dark); margin: 0; max-width: 36ch;"
              >
                {product.description}
              </p>
            </div>

            <!-- Right: screenshot or placeholder -->
            <div class="product-visual">
              {product.screenshot ? (
                <img
                  src={product.screenshot}
                  alt={`${product.name} screenshot`}
                  loading="lazy"
                  style="width: 100%; height: auto; display: block; border-radius: 4px; opacity: 0.9;"
                />
              ) : (
                <div
                  style="width: 100%; aspect-ratio: 16/9; border: 1px solid rgba(196,168,130,0.15); display: flex; align-items: center; justify-content: center; border-radius: 4px;"
                >
                  <p
                    style="font-family: var(--font-display); font-size: var(--text-caption); letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-ink-muted-dark); margin: 0;"
                  >
                    Coming Soon
                  </p>
                </div>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div
      style="border-top: 1px solid rgba(196, 168, 130, 0.2); padding: clamp(48px, 7vw, 96px) var(--content-padding-x); max-width: var(--max-width); margin: 0 auto; text-align: center;"
    >
      <p
        style="font-family: var(--font-display); font-size: var(--text-section); font-weight: 700; letter-spacing: -0.02em; color: var(--color-ink-dark); margin: 0 0 clamp(16px, 3vw, 24px);"
      >
        入会で全ツール使い放題
      </p>
      <p
        style="font-family: var(--font-jp); font-size: var(--text-body); line-height: 1.9; color: var(--color-ink-muted-dark); max-width: 48ch; margin: 0 auto clamp(32px, 5vw, 48px);"
      >
        AI建築サークルは、中小設計事務所・工務店のためのプラットフォーム。
        月額定額でArchi-Prismaが開発するすべてのツールにアクセスできます。
      </p>
      <a
        href="https://ai-archi-circle.jp"
        target="_blank"
        rel="noopener noreferrer"
        style="
          display: inline-flex;
          align-items: center;
          justify-content: center;
          min-height: 52px;
          padding: 0 32px;
          border: 1px solid var(--color-accent-dark);
          color: var(--color-ink-dark);
          font-family: var(--font-display);
          font-size: var(--text-nav);
          font-weight: 600;
          letter-spacing: 0.06em;
          text-transform: uppercase;
          text-decoration: none;
          transition: background-color 0.25s var(--ease), color 0.25s var(--ease);
        "
        class="cta-link"
      >
        AI建築サークルへ →
      </a>
    </div>
  </main>

  <footer
    style="background-color: var(--color-surface-dark); border-top: 1px solid rgba(196,168,130,0.15); padding: clamp(32px, 4vw, 48px) var(--content-padding-x);"
  >
    <div
      style="max-width: var(--max-width); margin: 0 auto; display: flex; flex-direction: column; gap: 16px;"
      class="products-footer-inner"
    >
      <div
        style="display: flex; flex-direction: row; justify-content: space-between; align-items: flex-start; gap: 16px; flex-wrap: wrap;"
      >
        <span
          style="font-family: var(--font-display); font-size: var(--text-caption); letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-ink-muted-dark);"
        >
          &copy; 2024&ndash;{currentYear} Archi-Prisma Design Works
        </span>
        <a
          href="/"
          style="font-family: var(--font-display); font-size: var(--text-caption); letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-ink-muted-dark); text-decoration: none;"
          class="link-animated"
        >
          ← Back to Home
        </a>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .product-row {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  @media (min-width: 768px) {
    .product-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: center;
    }
  }

  .cta-link:hover {
    background-color: var(--color-accent-dark);
    color: var(--color-surface-dark);
  }
</style>
