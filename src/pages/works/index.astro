---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WorksHero from '../../components/works/WorksHero.astro';
import WorksFeatured from '../../components/works/WorksFeatured.astro';
import WorksArchive from '../../components/works/WorksArchive.astro';
import WorksModal from '../../components/works/WorksModal.astro';
import WorksCta from '../../components/works/WorksCta.astro';
import { loadWorks, loadFeaturedWorks } from '../../lib/content';

const works = loadWorks();
const featured = loadFeaturedWorks();
const nonFeatured = works.filter(w => !w.featured);
const allDisplayed = [...featured, ...nonFeatured];

const eras = [
  { label: 'All', filter: 'all' },
  { label: '2024', filter: '2024' },
  { label: '2000–', filter: '2000s' },
  { label: '〜1999', filter: '1990s' },
];

const categories = [
  { label: 'All', filter: 'all' },
  { label: '都市開発', filter: 'urban' },
  { label: 'ホスピタリティ', filter: 'hospitality' },
  { label: '商業', filter: 'commercial' },
  { label: '文化', filter: 'cultural' },
];
---

<Layout
  title="Works | Archi-Prisma Design Works"
  description="Archi-Prisma Design Works の設計実績。1986年から現在まで、都市開発・ホテル・商業施設・住宅を手がけてきたプロジェクト一覧。"
  ogImage="https://archi-prisma.co.jp/assets/curated/yacht-club-aerial-day.jpg"
>
  <Header />

  <main class="page-main">
    <WorksHero count={works.length} />
    <WorksFeatured featured={featured} allDisplayed={allDisplayed} />
    <WorksArchive works={nonFeatured} allDisplayed={allDisplayed} eras={eras} categories={categories} />
    <WorksCta />
  </main>

  <WorksModal />

  <Footer />

  <!-- Project data for modal -->
  <script define:vars={{ allDisplayed }}>
    window.__PROJECTS = allDisplayed;
  </script>

  <script>
    import { createScrollEngine, initReveals } from '../../lib/scroll-engine';
    import { slugify } from '../../lib/content';
    import { gsap } from 'gsap';

    let filterController: AbortController | null = null;
    let modalController: AbortController | null = null;

    function init() {
      if (filterController) filterController.abort();
      if (modalController) modalController.abort();
      filterController = new AbortController();
      modalController = new AbortController();

      const engine = createScrollEngine();
      initReveals(engine.prefersReduced);

      // Featured parallax
      if (!engine.prefersReduced && window.matchMedia('(min-width: 768px)').matches) {
        document.querySelectorAll('.works-featured__img').forEach((img) => {
          gsap.to(img, {
            y: 40,
            ease: 'none',
            scrollTrigger: {
              trigger: img.closest('.works-featured__card'),
              start: 'top bottom',
              end: 'bottom top',
              scrub: 0.6,
            },
          });
        });
      }

      // ─── Multi-axis filter ───
      const eraFilterBtns = document.querySelectorAll<HTMLElement>('#era-filter button');
      const categoryFilterBtns = document.querySelectorAll<HTMLElement>('#category-filter button');
      const cards = document.querySelectorAll<HTMLElement>('.work-card');
      let activeEra = 'all';
      let activeCategory = 'all';

      function applyFilters() {
        let visibleCount = 0;
        cards.forEach((card) => {
          const cardEra = card.getAttribute('data-era') || '';
          const cardCat = card.getAttribute('data-category') || '';
          const matchEra = activeEra === 'all' || cardEra === activeEra;
          const matchCat = activeCategory === 'all' || cardCat === activeCategory;

          if (matchEra && matchCat) {
            if (card.classList.contains('is-hidden')) {
              card.classList.remove('is-hidden');
              card.removeAttribute('inert');
              card.removeAttribute('aria-hidden');
              card.querySelectorAll<HTMLElement>('[tabindex="-1"]').forEach(el => el.removeAttribute('tabindex'));
            }
            visibleCount++;
          } else {
            if (!card.classList.contains('is-hidden')) {
              card.classList.add('is-hidden');
              card.setAttribute('inert', '');
              card.setAttribute('aria-hidden', 'true');
              card.querySelectorAll<HTMLElement>('button, a, [href], input, select, textarea').forEach(el => el.setAttribute('tabindex', '-1'));
            }
          }
        });

        const status = document.getElementById('filter-status');
        if (status) status.textContent = `${visibleCount}件のプロジェクトを表示中`;

        // Zero results message
        const grid = document.getElementById('works-grid');
        if (grid) {
          let noResults = document.getElementById('no-results');
          if (visibleCount === 0) {
            if (!noResults) {
              noResults = document.createElement('p');
              noResults.id = 'no-results';
              noResults.setAttribute('role', 'status');
              noResults.style.cssText = 'grid-column: 1 / -1; text-align: center; padding: 3rem 1rem; font-family: var(--font-jp); font-size: var(--text-body); color: var(--color-ink-muted);';
              grid.appendChild(noResults);
            }
            noResults.textContent = '該当するプロジェクトがありません';
            noResults.hidden = false;
          } else if (noResults) {
            noResults.hidden = true;
          }
        }

        // Update active counts per filter buttons
        eraFilterBtns.forEach((btn) => {
          const filter = btn.getAttribute('data-filter') || 'all';
          const countEl = btn.querySelector('.works-filter__count');
          if (!countEl) return;
          let count = 0;
          cards.forEach((card) => {
            const cardEra = card.getAttribute('data-era') || '';
            const cardCat = card.getAttribute('data-category') || '';
            const matchEra = filter === 'all' || cardEra === filter;
            const matchCat = activeCategory === 'all' || cardCat === activeCategory;
            if (matchEra && matchCat) count++;
          });
          countEl.textContent = String(count);
        });

        categoryFilterBtns.forEach((btn) => {
          const filter = btn.getAttribute('data-filter') || 'all';
          const countEl = btn.querySelector('.works-filter__count');
          if (!countEl) return;
          let count = 0;
          cards.forEach((card) => {
            const cardEra = card.getAttribute('data-era') || '';
            const cardCat = card.getAttribute('data-category') || '';
            const matchEra = activeEra === 'all' || cardEra === activeEra;
            const matchCat = filter === 'all' || cardCat === filter;
            if (matchEra && matchCat) count++;
          });
          countEl.textContent = String(count);
        });
      }

      eraFilterBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          activeEra = btn.getAttribute('data-filter') || 'all';
          eraFilterBtns.forEach((b) => b.setAttribute('aria-pressed', 'false'));
          btn.setAttribute('aria-pressed', 'true');
          applyFilters();
        }, { signal: filterController!.signal });
      });

      categoryFilterBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          activeCategory = btn.getAttribute('data-filter') || 'all';
          categoryFilterBtns.forEach((b) => b.setAttribute('aria-pressed', 'false'));
          btn.setAttribute('aria-pressed', 'true');
          applyFilters();
        }, { signal: filterController!.signal });
      });

      // ─── Modal ───
      const projects = (window as any).__PROJECTS || [];
      const modal = document.getElementById('project-modal')!;
      const modalImg = document.getElementById('modal-img') as HTMLImageElement;
      const modalTitle = document.getElementById('modal-title')!;
      const modalMeta = document.getElementById('modal-meta')!;
      const modalDescription = document.getElementById('modal-description')!;
      const modalStory = document.getElementById('modal-story')!;
      const modalDetails = document.getElementById('modal-details')!;
      const modalPrev = document.getElementById('modal-prev') as HTMLButtonElement;
      const modalNext = document.getElementById('modal-next') as HTMLButtonElement;
      const modalClose = modal.querySelector('.modal__close') as HTMLButtonElement;
      const modalBackdrop = modal.querySelector('.modal__backdrop') as HTMLElement;
      const modalPanel = modal.querySelector('.modal__panel') as HTMLElement;
      const modalPageLink = document.getElementById('modal-page-link') as HTMLAnchorElement;
      let currentIdx = 0;
      let previousFocus: HTMLElement | null = null;

      function showProject(idx: number) {
        const p = projects[idx];
        if (!p) return;
        currentIdx = idx;

        if (p.image) {
          modalImg.src = p.image;
          modalImg.alt = `${p.title} — ${p.year} ${p.type}, ${p.region}`;
          modalImg.style.display = 'block';
        } else {
          modalImg.style.display = 'none';
        }
        modalMeta.textContent = `${p.year} — ${p.type} · ${p.region}`;
        modalTitle.textContent = p.title;
        modalDescription.textContent = p.description || '';
        modalDescription.style.display = p.description ? 'block' : 'none';
        modalStory.textContent = p.storyline || '';
        modalStory.style.display = p.storyline ? 'block' : 'none';

        // Build details as definition list
        let detailsHtml = '';
        if (p.scope) {
          detailsHtml += `<div class="modal__detail-row"><dt>Scope</dt><dd>${p.scope}</dd></div>`;
        }
        if (p.phase) {
          detailsHtml += `<div class="modal__detail-row"><dt>Phase</dt><dd>${p.phase}</dd></div>`;
        }
        if (p.category) {
          const catLabels: Record<string, string> = {
            urban: '都市開発',
            hospitality: 'ホスピタリティ',
            commercial: '商業',
            cultural: '文化',
          };
          detailsHtml += `<div class="modal__detail-row"><dt>Category</dt><dd>${catLabels[p.category] || p.category}</dd></div>`;
        }
        modalDetails.innerHTML = detailsHtml;

        // Detail page link
        if (modalPageLink) {
          modalPageLink.href = `/works/${slugify(p.title)}/`;
        }

        // Nav state
        modalPrev.disabled = idx === 0;
        modalNext.disabled = idx === projects.length - 1;
      }

      // Focus trap: cycle through focusable elements inside modal
      function trapFocus(e: KeyboardEvent) {
        if (e.key !== 'Tab' || modal.hidden) return;
        const focusable = modal.querySelectorAll<HTMLElement>(
          'button:not(:disabled), [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
        );
        if (focusable.length === 0) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }

      function openModal(idx: number) {
        previousFocus = document.activeElement as HTMLElement;
        showProject(idx);
        modal.hidden = false;
        modal.setAttribute('aria-labelledby', 'modal-title');
        requestAnimationFrame(() => modal.classList.add('modal--open'));
        document.body.style.overflow = 'hidden';
        modalClose.focus();
      }

      function closeModal() {
        modal.classList.remove('modal--open');
        function handleTransitionEnd() {
          modalPanel.removeEventListener('transitionend', handleTransitionEnd);
          modal.hidden = true;
          document.body.style.overflow = '';
          if (previousFocus) previousFocus.focus();
        }
        modalPanel.addEventListener('transitionend', handleTransitionEnd);
      }

      // Open triggers
      document.querySelectorAll<HTMLElement>('[data-project-idx]').forEach((el) => {
        el.addEventListener('click', () => {
          const idx = parseInt(el.getAttribute('data-project-idx') || '0', 10);
          openModal(idx);
        }, { signal: modalController!.signal });
      });

      // Close triggers
      modalClose.addEventListener('click', closeModal, { signal: modalController!.signal });
      modalBackdrop.addEventListener('click', closeModal, { signal: modalController!.signal });

      // Nav
      modalPrev.addEventListener('click', () => showProject(currentIdx - 1), { signal: modalController!.signal });
      modalNext.addEventListener('click', () => showProject(currentIdx + 1), { signal: modalController!.signal });

      // Keyboard: Escape, arrow nav, focus trap
      document.addEventListener('keydown', (e) => {
        if (modal.hidden) return;
        if (e.key === 'Escape') closeModal();
        else if (e.key === 'ArrowLeft' && currentIdx > 0) showProject(currentIdx - 1);
        else if (e.key === 'ArrowRight' && currentIdx < projects.length - 1) showProject(currentIdx + 1);
        else trapFocus(e);
      }, { signal: modalController!.signal });
    }

    import { registerPageInit } from '../../lib/scroll-engine';
    registerPageInit(init);
  </script>
</Layout>
