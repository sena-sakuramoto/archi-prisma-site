---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactInfo from '../../components/contact/ContactInfo.astro';
import ContactForm from '../../components/contact/ContactForm.astro';
import ContactFlow from '../../components/contact/ContactFlow.astro';

const inquiryTypes = [
  '設計・デザインのご相談',
  '事業計画・コンサルティング',
  'AI×建築サービスについて',
  'パートナーシップ・協業',
  'メディア取材',
  'その他',
];

const flowSteps = [
  { num: 1, title: 'お問い合わせ', desc: 'フォームまたはお電話でご連絡' },
  { num: 2, title: 'ヒアリング', desc: 'ご要望・条件をお伺い' },
  { num: 3, title: 'ご提案', desc: '概算・スケジュールのご提示' },
];
const contactStructuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact',
    url: 'https://archi-prisma.co.jp/contact/',
    inLanguage: 'ja-JP',
    description: 'Archi-Prisma Design Works へのお問い合わせページ。設計・AI導入・研修のご相談受付。',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://archi-prisma.co.jp/' },
      { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://archi-prisma.co.jp/contact/' },
    ],
  },
];
---

<Layout
  title="Contact | Archi-Prisma Design Works"
  description="Archi-Prisma Design Works へのお問い合わせ。設計・AI導入・研修のご相談はフォームまたはお電話で。東京都品川区上大崎。"
  ogImage="https://archi-prisma.co.jp/assets/curated/about-exterior.jpg"
  ogImageAlt="Archi-Prisma Design Works の事務所外観"
  structuredData={contactStructuredData}
>
  <Header />

  <main class="page-main">
    <section class="contact-split">
      <ContactInfo />

      <div class="contact-right">
        <div class="contact-visual img-grain img-vignette">
          <img
            src="/assets/curated/about-exterior.jpg"
            alt="Archi-Prisma Design Works 事務所外観"
            class="contact-visual__img img-graded"
            loading="eager"
            width="800"
            height="600"
          />
        </div>

        <ContactForm inquiryTypes={inquiryTypes} />
        <ContactFlow steps={flowSteps} />
      </div>
    </section>
  </main>

  <Footer />

  <script>
    import {
      validateForm,
      showErrors,
      clearErrors,
      extractFormData,
      buildMailtoUrl,
      submitToEndpoint,
    } from '../../lib/contact-form';

    const FORM_ENDPOINT = '';

    let controller: AbortController | null = null;

    function init() {
      if (controller) controller.abort();
      controller = new AbortController();
      const signal = controller.signal;

      // Reveals
      document.querySelectorAll('.reveal:not(.visible)').forEach((el) => {
        const delay = parseFloat((el as HTMLElement).style.getPropertyValue('--delay') || '0');
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          el.classList.add('visible');
          return;
        }
        const observer = new IntersectionObserver(
          ([entry]) => {
            if (entry.isIntersecting) {
              setTimeout(() => el.classList.add('visible'), delay * 1000);
              observer.disconnect();
            }
          },
          { threshold: 0.1 },
        );
        observer.observe(el);
      });

      const form = document.getElementById('contact-form') as HTMLFormElement;
      if (!form) return;

      const successEl = document.getElementById('form-success')!;
      const errorEl = document.getElementById('form-error')!;
      const errorsSummary = document.getElementById('form-errors-summary')!;
      const submitBtn = document.getElementById('form-submit') as HTMLButtonElement;
      const submitText = submitBtn.querySelector('.contact-form__submit-text') as HTMLElement;
      const submitLoading = submitBtn.querySelector('.contact-form__submit-loading') as HTMLElement;
      const formNote = document.getElementById('form-note')!;
      const retryBtn = document.getElementById('form-retry');

      if (FORM_ENDPOINT) {
        formNote.textContent = '通常2営業日以内にご返信いたします';
      }

      retryBtn?.addEventListener('click', () => {
        errorEl.hidden = true;
        form.hidden = false;
      }, { signal });

      // Clear previous error states
      clearErrors(form);
      errorsSummary.hidden = true;
      errorsSummary.textContent = '';

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        clearErrors(form);
        errorsSummary.hidden = true;
        errorsSummary.textContent = '';

        const errors = validateForm(form);

        if (errors.length > 0) {
          showErrors(form, errors);
          errorsSummary.textContent = `${errors.length}件のエラーがあります`;
          errorsSummary.hidden = false;
          errorsSummary.focus();
          return;
        }

        const formData = extractFormData(form);

        // Mailto fallback
        if (!FORM_ENDPOINT) {
          window.location.href = buildMailtoUrl(formData);
          return;
        }

        // GAS / API submission
        submitBtn.disabled = true;
        submitText.hidden = true;
        submitLoading.hidden = false;

        const result = await submitToEndpoint(FORM_ENDPOINT, formData);

        if (result.success) {
          form.hidden = true;
          formNote.hidden = true;
          successEl.hidden = false;
        } else {
          form.hidden = true;
          formNote.hidden = true;
          errorEl.hidden = false;
        }

        submitBtn.disabled = false;
        submitText.hidden = false;
        submitLoading.hidden = true;
      }, { signal });
    }

    import { registerPageInit } from '../../lib/scroll-engine';
    registerPageInit(init);
  </script>

  <style>
    .reveal { transition-delay: var(--delay, 0s); }

    .contact-split {
      min-height: calc(100vh - var(--header-height));
      display: grid;
      grid-template-columns: 1fr;
    }
    @media (min-width: 768px) {
      .contact-split { grid-template-columns: 1fr 1.1fr; }
    }

    /* ─── Right panel ─── */
    .contact-right {
      order: 2; display: flex; flex-direction: column;
    }
    @media (min-width: 768px) {
      .contact-right { order: 2; }
    }
    .contact-visual {
      overflow: hidden; min-height: 250px; max-height: 350px;
    }
    @media (min-width: 768px) {
      .contact-visual { max-height: 45vh; }
    }
    .contact-visual__img {
      width: 100%; height: 100%; object-fit: cover; display: block;
    }
  </style>
</Layout>
