---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

type ServiceItem = {
  name: string;
  step: string;
  recommend: string;
  desc: string;
  price?: string;
};

const services: Record<string, ServiceItem[]> = {
  entry: [
    { name: 'AI×建築セミナー', step: 'AIで何が変わるかを知る', recommend: 'まずは全体像を知りたい人。AIが気になるが、何から見ればいいか分からない人。', desc: '単発参加OK。サークル会員は月額内で受講可能。' },
    { name: 'AI × 建築サークル', step: 'まず、自分が触る', recommend: '継続して触りたい人。実際にツールを使いながら、自分の業務に置き換えて考えたい人。', desc: '全ツール使い放題。Discord + 月1イベント + セミナー受講。', price: '月額 5,000円' },
  ],
  org: [
    { name: '法人研修', step: '今のAIと、今できることを知る', recommend: '組織のAIリテラシーを底上げしたい会社。各自が「自分の業務も変えられるかもしれない」と考え始める状態をつくりたい会社。', desc: '今のAIを知り、今できることを知る。リテラシーを底上げし、「自分の業務も変えられるかもしれない」に脳を切り替える。部署別カスタマイズ。ハンズオン70%。' },
    { name: 'AI導入プログラム', step: '業務ごと変える', recommend: '学ぶだけで終わらせず、実際の業務フローまで変えたい会社。特定部門から導入を進めたい会社。', desc: '3〜6ヶ月。業務分析→構築→定着。研修の先へ進む会社のために。' },
  ],
  retain: [
    { name: 'AI保守顧問', step: '導入後、止まらないようにする', recommend: '研修や導入のあとに失速したくない会社。社内の推進役を継続的に支えたい会社。', desc: '月1面談 + チャットサポート。研修後でも導入後でも、推進役の伴走。' },
  ],
  demand: [
    { name: '受託開発', step: '自社専用のツールを作る', recommend: '既製ツールでは足りない会社。自社フローに合わせた仕組みを持ちたい会社。', desc: '既存ツールの限界が見えたとき。建築実務を知る開発チームが構築。' },
  ],
};
const servicesFlat = [...services.entry, ...services.org, ...services.retain, ...services.demand];

const values = [
  { num: '01', title: '実務で証明する', criterion: '使ってないなら語るな。' },
  { num: '02', title: '現場の課題から始める', criterion: '答えられないなら作るな。' },
  { num: '03', title: '1週間で届ける', criterion: '出せない規模なら分割しろ。' },
  { num: '04', title: '自分の手で作る', criterion: 'まず自分で30分やってみろ。' },
  { num: '05', title: '目の前の1人を動かす', criterion: '最近、誰かを本気にさせたか？' },
];

const tools = [
  { name: 'COMPASS', tagline: '工程管理', logo: '/assets/products/compass-logo.png', image: '/assets/curated/compass-gantt-ui.png', desc: '建設プロジェクトの工程管理をシンプルに。AI補助で予定立案から進捗追跡まで。', linePos: '45%' },
  { name: 'KAKOME', tagline: '写真指示書', logo: '/assets/products/kakome-logo-black.webp', image: '/assets/curated/kakome-report-ui.jpg', desc: '現場写真に指示を重ねて共有。口頭では伝わらないニュアンスをビジュアルで。', linePos: '55%' },
  { name: 'KOZO', tagline: '構造計算AI', logo: '/assets/products/kozo-logo.webp', image: null, desc: '構造計算の煩雑な作業をAIがアシスト。法改正にも素早く対応。', linePos: '40%' },
  { name: 'AI Commander', tagline: 'AI操作支援', logo: '/assets/products/aicommander-icon.png', image: '/assets/products/aicommander-screen.png', desc: 'ArchicadをAIで操る。設計作業の自動化・効率化をアドオンで実現。', linePos: '50%' },
];

const audiences = [
  { type: '設計事務所', pain: '人手不足で案件を回しきれない', outcome: '<span class="ai-num-inline">5人</span>で<span class="ai-num-inline">50人分</span>の業務を処理' },
  { type: 'ゼネコン', pain: '施工管理の属人化・報告書の工数', outcome: 'AI報告書で週<span class="ai-num-inline">10時間</span>削減' },
  { type: '工務店', pain: 'IT投資の判断材料がない', outcome: '実質負担を最小化して導入' },
];
const AI_CIRCLE_URL = 'https://ai-archi-circle.archi-prisma.co.jp/';
const siteUrl = 'https://archi-prisma.co.jp';
const aiPageUrl = `${siteUrl}/ai/`;
const aiPageTitle = 'AI × 建築事業 | 建築AI導入・法人研修・AI建築サークル | Archi-Prisma Design Works';
const aiPageDescription = '建築のプロを、AIで最強にする。AI建築サークル、法人研修、AI導入プログラム、保守顧問、受託開発まで、建築実務に効くAI導入を支援。';
const aiFaqs = [
  {
    question: 'AI × 建築では何を支援していますか？',
    answer: 'AI建築サークル、法人研修、AI導入プログラム、AI保守顧問、受託開発まで、建築実務に合わせて段階的に支援しています。',
  },
  {
    question: 'AI建築サークルでは何が使えますか？',
    answer: 'COMPASS、KAKOME、KOZO、AI Commander、MOJIOKO などの自社開発ツールを利用でき、Discord とイベント参加も含まれます。',
  },
  {
    question: '法人研修では何を得られますか？',
    answer: '今のAIと今できることを知り、AIリテラシーを底上げし、自分たちの業務を変えられる視点を組織に定着させます。',
  },
  {
    question: 'どんな会社に向いていますか？',
    answer: '設計事務所、ゼネコン、工務店など、人手不足、属人化、IT投資判断の不足といった課題を抱える会社に向いています。',
  },
];
const aiStructuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'AI × 建築事業',
    description: aiPageDescription,
    url: aiPageUrl,
    inLanguage: 'ja-JP',
    breadcrumb: { '@id': `${aiPageUrl}#breadcrumb` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    '@id': `${aiPageUrl}#breadcrumb`,
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: siteUrl,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'AI × 建築事業',
        item: aiPageUrl,
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'AI × 建築支援',
    description: aiPageDescription,
    url: aiPageUrl,
    areaServed: {
      '@type': 'Country',
      name: 'Japan',
    },
    provider: {
      '@type': 'Organization',
      name: 'Archi-Prisma Design Works',
      url: siteUrl,
      logo: `${siteUrl}/assets/branding/apdw-logo.png`,
    },
    audience: audiences.map((audience) => ({
      '@type': 'Audience',
      audienceType: audience.type,
    })),
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: 'AI × 建築サービス',
      itemListElement: servicesFlat.map((service, index) => ({
        '@type': 'Offer',
        position: index + 1,
        itemOffered: {
          '@type': 'Service',
          name: service.name,
          description: service.desc,
        },
        priceCurrency: 'JPY',
        ...(service.name === 'AI × 建築サークル'
          ? {
              price: '5000',
              url: AI_CIRCLE_URL,
              priceSpecification: {
                '@type': 'UnitPriceSpecification',
                price: '5000',
                priceCurrency: 'JPY',
                billingDuration: 'P1M',
              },
            }
          : {}),
      })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: '建築向けAIツール',
    itemListElement: tools.map((tool, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      item: {
        '@type': 'SoftwareApplication',
        name: tool.name,
        applicationCategory: 'BusinessApplication',
        operatingSystem: 'Web',
        description: tool.desc,
        image: `${siteUrl}${tool.image ?? tool.logo}`,
        publisher: {
          '@type': 'Organization',
          name: 'Archi-Prisma Design Works',
        },
      },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: aiFaqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer,
      },
    })),
  },
];
---

<Layout
  title={aiPageTitle}
  description={aiPageDescription}
  darkSpace={true}
  ogImage="https://archi-prisma.co.jp/assets/generated/ai-hero.jpg"
  ogImageAlt="夜の建築空間を背景にした AI × 建築事業ページのメインビジュアル"
  preloadImages={['/assets/generated/ai-hero.jpg']}
  structuredData={aiStructuredData}
>
  <Header />

  <main class="dark-space ai-page">

    <!-- ━━━ 1. HERO ━━━ -->
    <section class="ai-hero" data-section="hero">
      <div class="ai-hero__sticky">
        <div class="ai-hero__bg img-vignette img-grain">
          <img src="/assets/generated/ai-hero.jpg" alt="" aria-hidden="true" class="img-graded ai-hero__img" width="1920" height="823" loading="eager" fetchpriority="high" />
        </div>
        <div class="ai-hero__overlay"></div>
        <div class="ai-hero__content">
          <div class="ai-hero__inner">
            <div data-hero-item style="opacity: 0; transform: translateY(24px);">
              <h1 class="ai-hero__title" style="font-family: var(--font-display), var(--font-jp); font-size: var(--text-hero); font-weight: 800; color: var(--color-ink-dark); line-height: 1.2; letter-spacing: -0.03em; margin: 0;">
                <span class="ai-hero__word">建築のプロを、</span>
                <span class="ai-hero__word">AIで最強にする。</span>
              </h1>
            </div>
            <div data-hero-item style="opacity: 0; transform: translateY(24px); margin-top: 24px;">
              <p class="ai-hero__lead-copy" style="font-family: var(--font-body), var(--font-jp); font-size: var(--text-body); font-weight: 300; color: var(--color-ink-muted-dark); line-height: 2; margin: 0; max-width: 36ch;">
                <span class="ai-hero__copy-line">建築実務 × AI の両方を知る集団が、</span>
                <span class="ai-hero__copy-line">現場を変える。</span>
              </p>
            </div>
            <div data-hero-item class="ai-kpi-group" style="opacity: 0; transform: translateY(24px); margin-top: 40px; display: flex; align-items: center; gap: 2rem; flex-wrap: wrap;">
              <div class="ai-kpi" style="display: flex; flex-direction: column; gap: 0.15rem;">
                <span class="ai-kpi__value"><span class="ai-num">28+</span></span>
                <span class="ai-kpi__label">サークルメンバー</span>
              </div>
              <div class="ai-kpi__divider" style="width: 1px; height: 32px; background: rgba(255,255,255,0.08);"></div>
              <div class="ai-kpi" style="display: flex; flex-direction: column; gap: 0.15rem;">
                <span class="ai-kpi__value"><span class="ai-num">7+</span></span>
                <span class="ai-kpi__label">自社開発ツール</span>
              </div>
              <div class="ai-kpi__divider" style="width: 1px; height: 32px; background: rgba(255,255,255,0.08);"></div>
              <div class="ai-kpi" style="display: flex; flex-direction: column; gap: 0.15rem;">
                <span class="ai-kpi__value"><span class="ai-num">40</span>年</span>
                <span class="ai-kpi__label">建築実務の蓄積</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ━━━ 2. PROOF ━━━ -->
    <section class="section-pad" id="proof" data-section="proof" style="border-top: 1px solid rgba(196,168,130,0.15);">
      <div class="content-wide">
        <p style="font-family: var(--font-display); font-size: var(--text-nav); font-weight: 600; letter-spacing: 0.25em; text-transform: uppercase; color: var(--color-accent-dark); margin: 0 0 1.5rem;" class="reveal">
          WHO WE SERVE
        </p>
        <h2 class="ai-proof__heading reveal" style="font-family: var(--font-display), var(--font-jp); font-size: var(--text-section); font-weight: 700; color: var(--color-ink-dark); margin: 0 0 clamp(2rem, 4vw, 4rem); letter-spacing: -0.02em;">
          こんな課題を、解決する。
        </h2>
      </div>
      {audiences.map((a, i) => (
        <div class="reveal" style={`--delay: ${i * 0.08}s; --line-pos: ${i === 1 ? '55%' : i === 2 ? '40%' : '50%'}; border-top: 1px solid rgba(196,168,130,0.1);`}>
          <div class="line-section ai-proof__row" style="align-items: stretch;">
            <div class="ai-proof__meta" style="padding: clamp(32px, 4vw, 56px) 40px clamp(32px, 4vw, 56px) 0; display: flex; flex-direction: column; justify-content: center;">
              <span style="font-family: var(--font-display); font-size: var(--text-nav); font-weight: 700; color: var(--color-accent-dark); letter-spacing: 0.1em; text-transform: uppercase;">{a.type}</span>
              <p style="font-family: var(--font-body), var(--font-jp); font-size: var(--text-body); font-weight: 300; color: var(--color-ink-muted-dark); line-height: 1.9; margin: 0.75rem 0 0;">{a.pain}</p>
            </div>
            <div class="dividing-line" aria-hidden="true"></div>
            <div class="ai-proof__outcome-wrap" style="padding: clamp(32px, 4vw, 56px) 0 clamp(32px, 4vw, 56px) 40px; display: flex; align-items: center;">
              <div>
                <span style="font-family: var(--font-display); font-size: 0.6rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-accent-dark); opacity: 0.5; display: block; margin-bottom: 0.5rem;">OUTCOME</span>
                <p class="ai-outcome" style="font-size: var(--text-project); color: var(--color-ink-dark); margin: 0;" set:html={a.outcome}></p>
              </div>
            </div>
          </div>
        </div>
      ))}
      <!-- Real UI evidence -->
      <div class="content-wide" style="margin-top: clamp(3rem, 5vw, 5rem);">
        <div style="display: grid; grid-template-columns: 1fr; gap: 1.5rem;" class="reveal proof-ui-grid">
          <div class="img-grain" style="overflow: hidden; border-radius: 4px; border: 1px solid rgba(196,168,130,0.12);">
            <img src="/assets/curated/compass-gantt-ui.png" alt="COMPASS ガントチャートUI" style="width: 100%; height: auto; display: block;" loading="lazy" width="800" height="500" />
          </div>
          <div class="img-grain" style="overflow: hidden; border-radius: 4px; border: 1px solid rgba(196,168,130,0.12);">
            <img src="/assets/curated/kakome-report-ui.jpg" alt="KAKOME 写真指示書UI" style="width: 100%; height: auto; display: block;" loading="lazy" width="800" height="500" />
          </div>
        </div>
      </div>
    </section>

    <!-- ━━━ 3. VISION / MANIFESTO ━━━ -->
    <section class="ai-vision" id="vision" data-section="vision">
      <div class="ai-vision__bg img-vignette img-grain">
        <img src="/assets/generated/ai-vision.jpg" alt="" aria-hidden="true" class="img-graded ai-vision__img img-ken-burns" loading="lazy" width="1920" height="823" />
      </div>
      <div class="ai-vision__overlay"></div>
      <div class="ai-vision__content">
        <div class="line-section" style="--line-pos: 40%;">
          <div style="padding: clamp(4rem, 8vw, 8rem) 40px clamp(4rem, 8vw, 8rem) 0;">
            <p class="m-line m-line--muted">この業界には、力がある。</p>
            <p class="m-line m-line--muted">足りないのは、テクノロジーという武器だけだ。</p>
            <div style="height: 2rem;" aria-hidden="true"></div>
            <p class="m-line m-line--bold">それを手にしたとき、</p>
            <p class="m-line m-line--bold m-line--split">
              <span class="m-line__chunk">1人が10人分の成果を出せる</span>
              <span class="m-line__chunk">世界が始まる。</span>
            </p>
            <div style="height: 2rem;" aria-hidden="true"></div>
            <p class="m-line m-line--accent m-line--split">
              <span class="m-line__chunk">その世界を、</span>
              <span class="m-line__chunk">俺たちがつくる。</span>
            </p>
          </div>
          <div class="dividing-line" aria-hidden="true"></div>
          <div class="reveal ai-vision__points" style="padding: clamp(4rem, 8vw, 8rem) 0 clamp(4rem, 8vw, 8rem) 40px; display: flex; flex-direction: column; justify-content: center; gap: 1.5rem;">
            <div class="ai-vision__point" style="display: flex; align-items: flex-start; gap: 0.75rem;">
              <span class="ai-vision__point-num" style="font-family: var(--font-display); font-size: 0.6rem; font-weight: 600; letter-spacing: 0.15em; color: var(--color-accent-dark); opacity: 0.4; flex-shrink: 0; margin-top: 0.3rem;">01</span>
              <span class="ai-vision__point-text" style="font-family: var(--font-body), var(--font-jp); font-size: var(--text-body); font-weight: 300; color: var(--color-ink-muted-dark); line-height: 1.9;">設計事務所の5人が、50人分のプロジェクトを動かす</span>
            </div>
            <div class="ai-vision__point" style="display: flex; align-items: flex-start; gap: 0.75rem;">
              <span class="ai-vision__point-num" style="font-family: var(--font-display); font-size: 0.6rem; font-weight: 600; letter-spacing: 0.15em; color: var(--color-accent-dark); opacity: 0.4; flex-shrink: 0; margin-top: 0.3rem;">02</span>
              <span class="ai-vision__point-text" style="font-family: var(--font-body), var(--font-jp); font-size: var(--text-body); font-weight: 300; color: var(--color-ink-muted-dark); line-height: 1.9;">新人がAIに聞いて初日から現場を回す</span>
            </div>
            <div class="ai-vision__point" style="display: flex; align-items: flex-start; gap: 0.75rem;">
              <span class="ai-vision__point-num" style="font-family: var(--font-display); font-size: 0.6rem; font-weight: 600; letter-spacing: 0.15em; color: var(--color-accent-dark); opacity: 0.4; flex-shrink: 0; margin-top: 0.3rem;">03</span>
              <span class="ai-vision__point-text" style="font-family: var(--font-body), var(--font-jp); font-size: var(--text-body); font-weight: 300; color: var(--color-ink-muted-dark); line-height: 1.9;">「あの人がいないとわからない」がこの業界から消える</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ━━━ 4. SERVICE ━━━ -->
    <section class="section-pad" id="service" data-section="service" style="border-top: 1px solid rgba(196,168,130,0.15);">
      <div class="line-section" style="--line-pos: 35%;">
        <div style="padding-right: 40px;">
          <p style="font-family: var(--font-display); font-size: var(--text-nav); font-weight: 600; letter-spacing: 0.25em; text-transform: uppercase; color: var(--color-accent-dark); margin: 0 0 1.5rem;" class="reveal">
            SERVICE
          </p>
          <h2 class="ai-service__heading reveal" style="font-family: var(--font-display), var(--font-jp); font-size: var(--text-section); font-weight: 700; color: var(--color-ink-dark); margin: 0; letter-spacing: -0.02em; line-height: 1.3;">
            <span class="ai-service__line">あなたに合った</span>
            <span class="ai-service__line">始め方がある。</span>
          </h2>
        </div>
        <div class="dividing-line" aria-hidden="true"></div>
        <div style="padding-left: 40px;">
          <div class="ai-svc__list">
            {[...services.entry, ...services.org, ...services.retain, ...services.demand].map((svc, i) => (
              <details class="ai-svc__item reveal" style={`--delay: ${i * 0.06}s`}>
                <summary class="ai-svc__header">
                  <span class="ai-svc__name">{svc.name}</span>
                  <span class="ai-svc__step">{svc.step}</span>
                  <span class="ai-svc__toggle" aria-hidden="true"></span>
                </summary>
                <div class="ai-svc__body">
                  <div class="ai-svc__recommend">
                    <span class="ai-svc__recommend-label">こんな方におすすめ</span>
                    <p class="ai-svc__recommend-text">{svc.recommend}</p>
                  </div>
                  <p class="ai-svc__desc" style="font-family: var(--font-body), var(--font-jp); font-size: var(--text-body); color: var(--color-ink-dark); opacity: 0.7; line-height: 2; margin: 0;">{svc.desc}</p>
                  {svc.price && <span style="font-family: var(--font-display); font-size: var(--text-nav); font-weight: 600; color: var(--color-accent-dark); display: block; margin-top: 0.5rem; letter-spacing: 0.05em;">{svc.price}</span>}
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ━━━ 5. TOOLS ━━━ -->
    <section class="ai-tools" id="tools" style="padding-top: clamp(64px, 8vw, 120px);" data-section="tools">
      <div class="content-wide ai-tools__intro" style="padding-bottom: clamp(40px, 6vw, 80px);">
        <h2 class="ai-tools__heading reveal" style="font-family: var(--font-display); font-size: var(--text-section); font-weight: 700; letter-spacing: -0.02em; color: var(--color-ink-dark); margin: 0 0 12px; line-height: 1.15;">
          Tools
        </h2>
        <p class="ai-tools__lead reveal" style="font-family: var(--font-body), var(--font-jp); font-size: var(--text-body); line-height: 1.9; color: var(--color-ink-muted-dark); margin: 0; max-width: 40ch;">
