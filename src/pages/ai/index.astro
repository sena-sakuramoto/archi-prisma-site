        gsap.to('.vision-img', { y: '-10%', scrollTrigger: { trigger: '.vision', start: 'top bottom', end: 'bottom top', scrub: 0.5 } });

        // SERVICE CAROUSEL
        const svcSection = document.querySelector('.svc-section') as HTMLElement;
        const svcPinWrap = document.querySelector('.svc-pin-wrap') as HTMLElement;
        const textSlides = document.querySelectorAll<HTMLElement>('.svc-slide-text');
        const imgSlides = document.querySelectorAll<HTMLElement>('.svc-slide-img');
        const journeyFill = document.getElementById('svc-journey-fill');
        const journeyDots = document.querySelectorAll<HTMLElement>('.svc-journey__dot');
        const counterNum = document.getElementById('svc-counter-num');
        const total = textSlides.length;

        if (svcSection && svcPinWrap && total > 0) {
          const grid = document.querySelector('.svc-layout') as HTMLElement;
          if (grid) grid.style.gridTemplateColumns = '42% 1fr';

          // Set aria-hidden on non-active slides (JS-only, not in markup)
