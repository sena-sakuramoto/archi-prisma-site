    /* ── Reduced motion ── */
    @media (prefers-reduced-motion: reduce) {
      .ai-hero__img { transform: none !important; }
      .ai-vision__img { animation: none; }
      .m-line { opacity: 1 !important; }
    }
  </style>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import Lenis from 'lenis';
    gsap.registerPlugin(ScrollTrigger);

    let lenisInstance: Lenis | null = null;
    let tickerFn: ((time: number) => void) | null = null;
    let mm: gsap.MatchMedia | null = null;
    let observers: IntersectionObserver[] = [];

    function cleanup() {
      observers.forEach(o => o.disconnect());
      observers = [];
      if (mm) { mm.revert(); mm = null; }
      ScrollTrigger.getAll().forEach(t => t.kill());
      if (tickerFn) { gsap.ticker.remove(tickerFn); tickerFn = null; }
      if (lenisInstance) { lenisInstance.destroy(); lenisInstance = null; }
    }

    function init() {
      cleanup();

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReduced) {
        lenisInstance = new Lenis({ duration: 1.1, easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
        lenisInstance.on('scroll', ScrollTrigger.update);
        tickerFn = (time: number) => lenisInstance?.raf(time * 1000);
        gsap.ticker.add(tickerFn);
        gsap.ticker.lagSmoothing(0);
      }

      if (prefersReduced) {
        document.querySelectorAll('.reveal').forEach(el => el.classList.add('visible'));
        document.querySelectorAll('.m-line').forEach(el => el.classList.add('is-visible'));
        gsap.set('[data-hero-item]', { opacity: 1, y: 0 });
        gsap.set('.ai-hero__img', { scale: 1 });
        return;
      }

      // ── Reveals ──
      document.querySelectorAll('.reveal').forEach(el => {
        const obs = new IntersectionObserver(([e]) => { if (e.isIntersecting) { el.classList.add('visible'); obs.disconnect(); } }, { threshold: 0.12 });
        obs.observe(el); observers.push(obs);
      });

      const ease = 'power3.out';

      mm = gsap.matchMedia();

      // ── Desktop ──
      mm.add('(min-width: 768px)', () => {
        // HERO — clip-path reveal + staggered text (same pattern as Home Hero)
        const heroTl = gsap.timeline({ delay: 0.3 });
        heroTl
          .to('.ai-hero__img', { scale: 1, duration: 2.2, ease: 'power2.out' }, 0)
          .to('[data-hero-item]', { opacity: 1, y: 0, duration: 0.9, stagger: 0.15, ease }, 0.6);

        // Hero parallax on scroll
        gsap.to('.ai-hero__overlay', { background: 'rgba(12,12,12,0.92)', scrollTrigger: { trigger: '.ai-hero', start: 'top top', end: '70% top', scrub: true } });
        gsap.to('.ai-hero__img', { y: '12%', scrollTrigger: { trigger: '.ai-hero', start: 'top top', end: 'bottom top', scrub: true } });

        // VISION parallax + manifesto scrub
        gsap.to('.ai-vision__img', { y: '-10%', scrollTrigger: { trigger: '.ai-vision', start: 'top bottom', end: 'bottom top', scrub: 0.5 } });

        document.querySelectorAll('.m-line').forEach((line, i) => {
          gsap.to(line, {
            opacity: 1,
            duration: 0.8,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: '.ai-vision',
              start: `${15 + i * 8}% center`,
              once: true,
              onEnter: () => line.classList.add('is-visible'),
            },
          });
        });

        return () => {};
      });

      // ── Mobile ──
      mm.add('(max-width: 767px)', () => {
        gsap.set('[data-hero-item]', { opacity: 1, y: 0 });
        gsap.set('.ai-hero__img', { scale: 1 });

        gsap.to('.ai-hero__img', {
          y: '8%',
          ease: 'none',
          scrollTrigger: {
            trigger: '.ai-hero',
            start: 'top top',
            end: 'bottom top',
            scrub: 0.6,
          },
        });

        gsap.to('.ai-vision__img', {
          y: '-6%',
          ease: 'none',
          scrollTrigger: {
            trigger: '.ai-vision',
            start: 'top bottom',
            end: 'bottom top',
            scrub: 0.6,
          },
        });

        document.querySelectorAll<HTMLElement>('.ai-tool__shot img, .ai-personal__image img').forEach((media) => {
          const trigger = media.closest('.ai-tool, .ai-personal');
          if (!trigger) return;

          gsap.fromTo(
            media,
            { y: '-2%' },
            {
              y: '6%',
              ease: 'none',
              scrollTrigger: {
                trigger,
                start: 'top bottom',
                end: 'bottom top',
                scrub: 0.7,
              },
            }
          );
        });

        document.querySelectorAll('.m-line').forEach(line => {
          const obs = new IntersectionObserver(([e]) => {
            if (e.isIntersecting) { (line as HTMLElement).style.opacity = '1'; line.classList.add('is-visible'); obs.disconnect(); }
          }, { threshold: 0.3 });
          obs.observe(line); observers.push(obs);
        });

        return () => {};
      });

      // Header dark space awareness
      const header = document.getElementById('site-header') ?? document.getElementById('mobile-header');
      const darkSections = document.querySelectorAll('.dark-space');
      if (header && darkSections.length > 0) {
        const observer = new IntersectionObserver(
          (entries) => {
            const isInDark = entries.some(e => e.isIntersecting);
            header.setAttribute('data-space', isInDark ? 'dark' : 'light');
          },
          { rootMargin: '-64px 0px -90% 0px' }
        );
        darkSections.forEach(el => observer.observe(el));
      }
    }

    import { registerPageInit } from '../../lib/scroll-engine';
    registerPageInit(init);
  </script>
</Layout>
