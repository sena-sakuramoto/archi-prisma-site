---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

/* Images kept for potential future use:
 * /assets/generated/ai-service-seminar.jpg
 * /assets/generated/ai-service-circle.jpg
 * /assets/generated/ai-service-training.jpg
 * /assets/generated/ai-service-program.jpg
 * /assets/generated/ai-service-consulting.jpg
 * /assets/generated/ai-service-development.jpg
 */
const services = {
  entry: [
    { name: 'AI×建築セミナー', step: 'AIで何が変わるかを知る', desc: '単発参加OK。サークル会員は月額内で受講可能。' },
    { name: 'AI × 建築サークル', step: 'まず、自分が触る', desc: '全ツール使い放題。Discord + 月1イベント + セミナー受講。', price: '月額 5,000円' },
  ],
  org: [
    { name: '法人研修', step: '全員が触れる状態をつくる', desc: '部署別カスタマイズ。ハンズオン70%。共通言語をつくる。' },
    { name: 'AI導入プログラム', step: '業務ごと変える', desc: '3〜6ヶ月。業務分析→構築→定着。研修の先へ進む会社のために。' },
  ],
  retain: [
    { name: 'AI保守顧問', step: '導入後、止まらないようにする', desc: '月1面談 + チャットサポート。研修後でも導入後でも、推進役の伴走。' },
  ],
  demand: [
    { name: '受託開発', step: '自社専用のツールを作る', desc: '既存ツールの限界が見えたとき。建築実務を知る開発チームが構築。' },
  ],
};
const servicesFlat = [...services.entry, ...services.org, ...services.retain, ...services.demand];

const values = [
  { num: '01', title: '実務で証明する', criterion: '使ってないなら語るな。' },
  { num: '02', title: '現場の課題から始める', criterion: '答えられないなら作るな。' },
  { num: '03', title: '1週間で届ける', criterion: '出せない規模なら分割しろ。' },
  { num: '04', title: '自分の手で作る', criterion: 'まず自分で30分やってみろ。' },
  { num: '05', title: '目の前の1人を動かす', criterion: '最近、誰かを本気にさせたか？' },
];

const tools = [
  { name: 'COMPASS', tagline: '工程管理', logo: '/assets/products/compass-logo.png', image: '/assets/curated/compass-gantt-ui.png' },
  { name: 'KAKOME', tagline: '写真指示書', logo: '/assets/products/kakome-logo-black.webp', image: '/assets/curated/kakome-report-ui.jpg' },
  { name: 'KOZO', tagline: '構造計算AI', logo: '/assets/products/kozo-logo.webp', image: null },
  { name: 'AI Commander', tagline: 'AI操作支援', logo: '/assets/products/aicommander-icon.png', image: '/assets/products/aicommander-screen.png' },
];

const audiences = [
  { type: '設計事務所', pain: '人手不足で案件を回しきれない', outcome: '5人で50人分の業務を処理' },
  { type: 'ゼネコン', pain: '施工管理の属人化・報告書の工数', outcome: 'AI報告書で週10時間削減' },
  { type: '工務店', pain: 'IT投資の判断材料がない', outcome: '実質負担を最小化して導入' },
];
---

<Layout
  title="AI × 建築事業 | Archi-Prisma Design Works"
  description="建築のプロを、AIで最強にする。AI導入プログラム、法人研修、保守顧問、受託開発。"
  darkSpace={true}
  ogImage="https://archi-prisma.co.jp/assets/generated/ai-hero.jpg"
  preloadImages={['/assets/generated/ai-hero.jpg']}
>
  <Header />

  <!-- Page-specific JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'AI × 建築事業',
    description: '建築のプロを、AIで最強にする。AI導入プログラム、法人研修、保守顧問、受託開発。',
    url: 'https://archi-prisma.co.jp/ai/',
    provider: {
      '@type': 'Organization',
      name: 'Archi-Prisma Design Works',
      alternateName: 'APDW',
      url: 'https://archi-prisma.co.jp',
      logo: 'https://archi-prisma.co.jp/assets/branding/apdw-logo.png',
    },
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: 'AI × 建築 商品ライン',
      itemListElement: servicesFlat.map((s, i) => {
        const offer: Record<string, unknown> = {
          '@type': 'Offer',
          position: i + 1,
          name: s.name,
          description: s.desc,
          priceCurrency: 'JPY',
        };
        // サークル: public monthly price
        if (s.name === 'AI × 建築サークル') {
          offer.price = '5000';
          offer.priceSpecification = {
            '@type': 'UnitPriceSpecification',
            price: '5000',
            priceCurrency: 'JPY',
            billingDuration: 'P1M',
          };
        }
        return offer;
      }),
    },
  })} />

  <main class="dark-space ai-page">

    <!-- ━━━ 1. HERO ━━━ -->
    <section class="hero-wrap" data-section="hero">
      <div class="hero-sticky">
        <div class="hero-bg img-vignette">
          <img src="/assets/generated/ai-hero.jpg" alt="" aria-hidden="true" class="img-graded hero-img" width="1920" height="823" />
        </div>
        <div class="hero-overlay"></div>
        <div class="hero-grid-lines" aria-hidden="true"><span></span><span></span><span></span><span></span></div>
        <div class="hero-content">
          <div class="hero-inner">
            <img src="/assets/branding/apdw-dev-logo.png" alt="ARCHI-PRISMA" class="hero-logo" width="400" height="80" />
            <h1 class="hero-title">
              <span class="hero-word">建築のプロを、</span>
              <span class="hero-word">AIで最強にする。</span>
            </h1>
            <p class="hero-sub">建築実務 × AI の両方を知る集団が、現場を変える。</p>
            <!-- Credibility signal in hero -->
            <div class="hero-proof">
              <div class="hero-proof-item">
                <span class="hero-proof-num">28+</span>
                <span class="hero-proof-label">サークルメンバー</span>
              </div>
              <div class="hero-proof-divider"></div>
              <div class="hero-proof-item">
                <span class="hero-proof-num">6</span>
                <span class="hero-proof-label">自社開発ツール</span>
              </div>
              <div class="hero-proof-divider"></div>
              <div class="hero-proof-item">
                <span class="hero-proof-num">40年</span>
                <span class="hero-proof-label">建築実務の蓄積</span>
              </div>
            </div>
            <div class="hero-scroll-hint">
              <span class="hero-scroll-line"></span>
              <span class="hero-scroll-label">SCROLL</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ━━━ 2. PROOF — who we serve, what changes ━━━ -->
    <section class="proof-section" data-section="proof">
      <div class="proof-inner">
        <span class="section-label reveal">WHO WE SERVE</span>
        <h2 class="proof-heading reveal">こんな課題を、解決する。</h2>
        <div class="proof-grid">
          {audiences.map((a) => (
            <div class="proof-card reveal">
              <span class="proof-type">{a.type}</span>
              <p class="proof-pain">{a.pain}</p>
              <div class="proof-arrow" aria-hidden="true">→</div>
              <p class="proof-outcome">{a.outcome}</p>
            </div>
          ))}
        </div>
        <!-- Real UI evidence — two products side by side -->
        <div class="proof-ui-grid reveal">
          <div class="proof-ui">
            <img src="/assets/curated/compass-gantt-ui.png" alt="COMPASS ガントチャートUI" class="proof-ui-img" loading="lazy" width="800" height="500" />
            <p class="proof-ui-caption">COMPASS — 工程管理ガントチャート</p>
          </div>
          <div class="proof-ui">
            <img src="/assets/curated/kakome-report-ui.jpg" alt="KAKOME 写真指示書UI" class="proof-ui-img" loading="lazy" width="800" height="500" />
            <p class="proof-ui-caption">KAKOME — 写真指示書レポート</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ━━━ 3. VISION + MANIFESTO (統合) ━━━ -->
    <section class="vision" data-section="vision">
      <div class="vision-bg">
        <img src="/assets/generated/ai-vision.jpg" alt="" aria-hidden="true" class="img-graded vision-img" loading="lazy" width="1920" height="823" />
      </div>
      <div class="vision-overlay"></div>
      <div class="vision-content">
        <div class="vision-manifesto">
          <p class="m-line m-line--muted">この業界には、力がある。</p>
          <p class="m-line m-line--muted">足りないのは、テクノロジーという武器だけだ。</p>
          <div class="m-break" aria-hidden="true"></div>
          <p class="m-line m-line--bold">それを手にしたとき、</p>
          <p class="m-line m-line--bold">1人が10人分の成果を出せる世界が始まる。</p>
          <div class="m-break" aria-hidden="true"></div>
          <p class="m-line m-line--accent">その世界を、俺たちがつくる。</p>
        </div>
        <div class="vision-future reveal">
          <div class="vision-ev-item">
            <span>設計事務所の5人が、50人分のプロジェクトを動かす</span>
          </div>
          <div class="vision-ev-item">
            <span>新人がAIに聞いて初日から現場を回す</span>
          </div>
          <div class="vision-ev-item">
            <span>「あの人がいないとわからない」がこの業界から消える</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ━━━ 5. SERVICE — accordion ━━━ -->
    <section class="svc" data-section="service">
      <div class="svc__inner">
        <span class="section-label reveal">SERVICE</span>
        <h2 class="svc__title reveal">あなたに合った始め方がある。</h2>

        <div class="svc__list">
          {[...services.entry, ...services.org, ...services.retain, ...services.demand].map((svc, i) => (
            <details class="svc__item reveal" style={`--delay: ${i * 0.05}s`}>
              <summary class="svc__header">
                <span class="svc__name">{svc.name}</span>
                <span class="svc__step">{svc.step}</span>
                <span class="svc__toggle" aria-hidden="true"></span>
              </summary>
              <div class="svc__body">
                <p class="svc__desc">{svc.desc}</p>
                {svc.price && <span class="svc__price">{svc.price}</span>}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- VALUES merged into PERSONAL section below -->

    <!-- ━━━ 8. TOOLS ━━━ -->
    <section class="tools-section" data-section="tools">
      <div class="tools-header">
        <span class="section-label reveal">TOOLS</span>
        <h2 class="tools-heading reveal">自社開発ツール</h2>
        <p class="tools-sub reveal">サークルメンバーは全て使い放題。</p>
      </div>
      <div class="tools-track-wrap" role="region" aria-label="ツール一覧" tabindex="0">
        <div class="tools-track" id="tools-track">
          {tools.map((tool) => (
            <div class="tool-card">
              <img src={tool.logo} alt={tool.name} loading="lazy" class="tool-logo" width="120" height="40" />
              <span class="tool-tagline">{tool.tagline}</span>
              <h3 class="tool-name">{tool.name}</h3>
              {tool.image && (
                <div class="tool-screenshot"><img src={tool.image} alt="" loading="lazy" width="800" height="500" /></div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ━━━ 6. PERSONAL + VALUES ━━━ -->
    <section class="personal-section" data-section="personal">
      <div class="personal-inner">
        <div class="personal-layout reveal">
          <div class="personal-photo">
            <img
              src="/assets/team-sakuramoto-sena.jpg"
              alt="櫻本 聖成"
              class="personal-img"
              loading="lazy"
              width="400"
              height="533"
            />
            <div class="personal-sign">
              <span class="personal-name">櫻本 聖成</span>
              <span class="personal-role">代表取締役 / CEO</span>
            </div>
          </div>
          <div class="personal-text">
            <p class="personal-message">
              今も自分で設計して、チームでプロジェクトを回しています。<br />
              だから分かる。AIがどこに効いて、どこは人間がやるべきか。<br /><br />
              「難しそう」「うちには早い」—<br />
              そう思っている方ほど、一度話してみてください。<br />
              30分で、見える景色が変わります。
            </p>
          </div>
        </div>
        <!-- 行動原則（同じセクション内、罫線で分離） -->
        <div class="personal-values reveal">
          <h3 class="personal-values__heading">行動原則</h3>
          <ol class="personal-values__list">
            {values.map((v) => (
              <li class="personal-values__item">
                <span class="personal-values__title">{v.title}</span>
                <span class="personal-values__criterion">{v.criterion}</span>
              </li>
            ))}
          </ol>
        </div>
        </div>
      </div>
    </section>

    <!-- ━━━ 10. CTA ━━━ -->
    <section class="cta-section" data-section="cta">
      <div class="cta-inner reveal">
        <div class="cta-line" aria-hidden="true"></div>
        <p class="cta-heading">まずは、話してみませんか。</p>
        <p class="cta-sub">30分のオンライン面談（無料）で、御社に合う進め方をご提案します。</p>
        <div class="cta-steps">
          <div class="cta-step"><span class="cta-step-num">1</span><span>面談で状況を聞く</span></div>
          <div class="cta-step"><span class="cta-step-num">2</span><span>セミナーで体感する</span></div>
          <div class="cta-step"><span class="cta-step-num">3</span><span>サークルで触ってみる</span></div>
        </div>
        <div class="cta-buttons">
          <a href="/contact/" class="cta-primary">無料面談を予約する</a>
          <a href="https://ai-archi-circle.jp" target="_blank" rel="noopener noreferrer" class="cta-outline">セミナー・サークルを見る</a>
        </div>
      </div>
    </section>

  </main>

  <!-- No-JS fallback: make all services visible -->
  <noscript>
    <style>
      /* accordion needs no noscript overrides */
      .m-line { opacity: 1 !important; }
      .hero-logo, .hero-sub, .hero-proof { opacity: 1 !important; }
      .hero-img { transform: none !important; }
      .value-item { opacity: 1 !important; transform: none !important; }
      .reveal { opacity: 1 !important; transform: none !important; }
    </style>
  </noscript>

  <div class="dark-space"><Footer /></div>

  <style>
    .ai-page { --pad: var(--content-padding-x); --mw: var(--max-width); }
    .section-label {
      font-family: var(--font-display); font-size: 0.6rem; font-weight: 700;
      letter-spacing: 0.35em; text-transform: uppercase;
      color: var(--color-accent-dark); display: block; margin-bottom: 1.5rem;
    }

    /* ── HERO ── */
    .hero-wrap { position: relative; height: 220vh; }
    .hero-sticky { position: sticky; top: 0; height: 100vh; overflow: hidden; display: flex; align-items: center; }
    .hero-bg { position: absolute; inset: 0; }
    .hero-img { width: 100%; height: 100%; object-fit: cover; transform: scale(1.1); will-change: transform; }
    .hero-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(12,12,12,0.82) 0%, rgba(12,12,12,0.35) 50%, rgba(12,12,12,0.65) 100%); z-index: 1; }
    .hero-grid-lines { position: absolute; inset: 0; z-index: 1; display: flex; justify-content: space-evenly; pointer-events: none; opacity: 0.035; }
    .hero-grid-lines span { width: 1px; height: 100%; background: var(--color-ink-dark); }
    .hero-content { position: relative; z-index: 2; max-width: var(--mw); margin: 0 auto; padding: 0 var(--pad); width: 100%; }
    .hero-inner { max-width: 700px; }
    .hero-logo { height: 22px; width: auto; opacity: 0; margin-bottom: 2.5rem; display: block; }
    .hero-title { font-family: var(--font-jp); font-size: clamp(2.2rem, 6vw, 4.2rem); font-weight: 800; color: var(--color-ink-dark); line-height: 1.3; letter-spacing: -0.03em; margin-bottom: 1.25rem; }
    .hero-word { display: block; overflow: hidden; }
    .hero-sub { font-family: var(--font-jp); font-size: var(--text-body); font-weight: 300; color: var(--color-ink-muted-dark); line-height: 2; opacity: 0; max-width: 420px; margin-bottom: 2.5rem; }
    .hero-proof { display: flex; align-items: center; gap: 2rem; opacity: 0; flex-wrap: wrap; }
    .hero-proof-item { display: flex; flex-direction: column; gap: 0.2rem; }
    .hero-proof-num { font-family: var(--font-display); font-size: 1.5rem; font-weight: 800; color: var(--color-ink-dark); letter-spacing: -0.02em; }
    .hero-proof-label { font-family: var(--font-jp); font-size: 0.7rem; font-weight: 300; color: var(--color-ink-muted-dark); }
    .hero-proof-divider { width: 1px; height: 32px; background: rgba(255,255,255,0.1); }
    .hero-scroll-hint { position: absolute; bottom: -28vh; left: 0; display: flex; flex-direction: column; align-items: center; gap: 0.6rem; opacity: 0; }
    .hero-scroll-line { width: 1px; height: 40px; background: linear-gradient(to bottom, var(--color-accent-dark), transparent); }
    .hero-scroll-label { font-family: var(--font-display); font-size: 0.5rem; font-weight: 600; letter-spacing: 0.4em; color: var(--color-accent-dark); }

    /* ── PROOF ── */
    .proof-section { padding: 10rem 0 6rem; }
    .proof-inner { max-width: var(--mw); margin: 0 auto; padding: 0 var(--pad); }
    .proof-heading { font-family: var(--font-jp); font-size: clamp(1.4rem, 2.5vw, 2rem); font-weight: 700; color: var(--color-ink-dark); margin-bottom: 3rem; }
    .proof-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem; margin-bottom: 4rem; }
    .proof-card { padding: 2rem; border: 1px solid rgba(255,255,255,0.06); border-radius: 3px; transition: border-color 0.3s ease; }
    .proof-card:hover { border-color: rgba(196,168,130,0.25); }
    .proof-type { font-family: var(--font-jp); font-size: 0.75rem; font-weight: 700; color: var(--color-accent-dark); letter-spacing: 0.1em; display: block; margin-bottom: 0.75rem; }
    .proof-pain { font-family: var(--font-jp); font-size: var(--text-body); font-weight: 300; color: var(--color-ink-muted-dark); line-height: 1.8; margin-bottom: 1rem; }
    .proof-arrow { color: var(--color-accent-dark); font-size: 1rem; margin-bottom: 0.5rem; }
    .proof-outcome { font-family: var(--font-jp); font-size: var(--text-body); font-weight: 600; color: var(--color-ink-dark); line-height: 1.8; }
    .proof-ui-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
    @media (min-width: 768px) { .proof-ui-grid { grid-template-columns: 1fr 1fr; } }
    .proof-ui { overflow: hidden; border-radius: 4px; border: 1px solid rgba(255,255,255,0.06); transition: border-color 0.3s ease; }
    .proof-ui:hover { border-color: rgba(196,168,130,0.2); }
    .proof-ui-img { width: 100%; height: auto; display: block; }
    .proof-ui-caption { font-family: var(--font-jp); font-size: 0.7rem; font-weight: 300; color: var(--color-ink-muted-dark); padding: 0.75rem 1rem; background: rgba(255,255,255,0.02); }

    /* ── MANIFESTO ── */
    .manifesto { min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 8rem var(--pad); }
    .manifesto-inner { max-width: 720px; }
    .m-line { font-family: var(--font-jp); margin: 0; opacity: 0; transition: opacity 0.6s ease; }
    .m-line--muted { font-size: clamp(0.9rem, 1.5vw, 1.1rem); font-weight: 300; color: var(--color-ink-muted-dark); line-height: 2.6; }
    .m-line--bold { font-size: clamp(1.2rem, 2.5vw, 1.8rem); font-weight: 700; color: var(--color-ink-dark); line-height: 2; }
    .m-line--accent { font-size: clamp(1.3rem, 2.8vw, 2.2rem); font-weight: 800; color: var(--color-accent-dark); line-height: 2; }
    .m-break { height: 2rem; }
    .m-line.is-visible { opacity: 1; }

    /* ── VISION ── */
    .vision { position: relative; min-height: 100vh; display: flex; align-items: center; overflow: hidden; }
    .vision-bg { position: absolute; inset: 0; }
    .vision-bg img { width: 100%; height: 100%; object-fit: cover; transform: scale(1.05); }
    .vision-overlay { position: absolute; inset: 0; background: linear-gradient(to right, rgba(12,12,12,0.9) 0%, rgba(12,12,12,0.5) 50%, rgba(12,12,12,0.3) 100%); z-index: 1; }
    .vision-content { position: relative; z-index: 2; max-width: var(--mw); margin: 0 auto; padding: 6rem var(--pad); max-width: 640px; }
    .vision-heading { font-family: var(--font-jp); font-size: clamp(1.5rem, 3.5vw, 2.8rem); font-weight: 800; color: var(--color-ink-dark); line-height: 1.5; letter-spacing: -0.02em; margin-bottom: 0.75rem; }
    .vision-sub { font-family: var(--font-jp); font-size: clamp(0.85rem, 1.1vw, 1rem); font-weight: 500; color: var(--color-accent-dark); margin-bottom: 2.5rem; }
    .vision-evidence { display: flex; flex-direction: column; gap: 1rem; }
    .vision-ev-item { display: flex; align-items: flex-start; gap: 0.75rem; font-family: var(--font-jp); font-size: var(--text-body); font-weight: 300; color: var(--color-ink-muted-dark); line-height: 1.8; }
    .vision-ev-icon { color: var(--color-accent-dark); flex-shrink: 0; margin-top: 0.15rem; }

    /* ── SERVICE — clean accordion ── */
    .svc { padding: clamp(5rem, 8vw, 8rem) 0; }
    .svc__inner { max-width: 800px; margin: 0 auto; padding: 0 var(--pad); }
    .svc__title {
      font-family: var(--font-jp); font-size: clamp(1.3rem, 2.2vw, 1.8rem);
      font-weight: 700; color: var(--color-ink-dark); margin-bottom: 3rem;
    }
    .svc__list { border-top: 1px solid rgba(255,255,255,0.08); }
    .svc__item {
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .svc__header {
      display: flex; align-items: center; gap: 1rem;
      padding: clamp(1.25rem, 2vw, 1.75rem) 0;
      cursor: pointer; list-style: none; width: 100%;
    }
    .svc__header::-webkit-details-marker { display: none; }
    .svc__header::marker { display: none; content: ''; }
    .svc__name {
      font-family: var(--font-jp); font-size: clamp(1rem, 1.4vw, 1.2rem);
      font-weight: 700; color: var(--color-ink-dark);
      flex-shrink: 0;
    }
    .svc__step {
      font-family: var(--font-jp); font-size: 0.85rem;
      color: var(--color-ink-muted-dark);
      flex: 1; text-align: right;
    }
    .svc__toggle {
      width: 20px; height: 20px; flex-shrink: 0;
      position: relative;
    }
    .svc__toggle::before, .svc__toggle::after {
      content: ''; position: absolute;
      background: var(--color-ink-muted-dark);
      transition: transform 0.3s var(--ease);
    }
    .svc__toggle::before { width: 12px; height: 1px; top: 50%; left: 50%; transform: translate(-50%, -50%); }
    .svc__toggle::after { width: 1px; height: 12px; top: 50%; left: 50%; transform: translate(-50%, -50%); }
    .svc__item[open] .svc__toggle::after { transform: translate(-50%, -50%) rotate(90deg); }
    .svc__body {
      padding: 0 0 clamp(1.25rem, 2vw, 1.75rem);
    }
    .svc__desc {
      font-family: var(--font-jp); font-size: var(--text-body);
      color: var(--color-ink-dark); opacity: 0.7; line-height: 2;
      margin: 0;
    }
    .svc__price {
      font-family: var(--font-body); font-size: 0.85rem;
      color: var(--color-accent-dark); display: block; margin-top: 0.5rem;
    }

    /* ── VALUES ── */
    /* ── VALUES (Vercel/Linear hybrid: 5-col grid, title+criterion, numbered) ── */
    .values-section { padding: clamp(4rem, 6vw, 6rem) 0 clamp(2rem, 3vw, 3rem); border-top: 1px solid rgba(255,255,255,0.04); }
    .values-inner { max-width: var(--mw); margin: 0 auto; padding: 0 var(--pad); }
    .values-heading {
      font-family: var(--font-jp); font-size: clamp(1.3rem, 2.2vw, 1.8rem);
      font-weight: 700; color: var(--color-ink-dark); margin-bottom: 3rem;
    }
    .values-list {
      list-style: none; margin: 0; padding: 0;
      display: grid; grid-template-columns: 1fr; gap: 0;
      counter-reset: value-counter;
    }
    @media (min-width: 768px) { .values-list { grid-template-columns: repeat(2, 1fr); } }
    @media (min-width: 1200px) { .values-list { grid-template-columns: repeat(5, 1fr); } }
    .value-item {
      padding: clamp(1.5rem, 2.5vw, 2rem);
      border-top: 1px solid rgba(255,255,255,0.06);
      counter-increment: value-counter;
      position: relative;
    }
    @media (min-width: 768px) {
      .value-item { border-right: 1px solid rgba(255,255,255,0.04); }
      .value-item:nth-child(2n) { border-right: none; }
    }
    @media (min-width: 1200px) {
      .value-item:nth-child(2n) { border-right: 1px solid rgba(255,255,255,0.04); }
      .value-item:last-child { border-right: none; }
    }
    .value-item::before {
      content: counter(value-counter, decimal-leading-zero);
      font-family: var(--font-display); font-size: 0.65rem; font-weight: 600;
      letter-spacing: 0.1em; color: var(--color-accent-dark); opacity: 0.4;
      display: block; margin-bottom: 0.75rem;
    }
    .value-title {
      font-family: var(--font-jp); font-size: clamp(0.95rem, 1.2vw, 1.1rem);
      font-weight: 700; color: var(--color-ink-dark);
      display: block; margin-bottom: 0.5rem; line-height: 1.5;
    }
    .value-criterion {
      font-family: var(--font-jp); font-size: 0.85rem;
      font-weight: 400; color: var(--color-ink-dark); opacity: 0.55;
      line-height: 1.8; display: block;
    }

    /* ── TOOLS ── */
    .tools-section { padding: 8rem 0; overflow: hidden; }
    .tools-header { max-width: var(--mw); margin: 0 auto; padding: 0 var(--pad); margin-bottom: 3rem; }
    .tools-heading { font-family: var(--font-jp); font-size: var(--text-section); font-weight: 700; color: var(--color-ink-dark); margin-bottom: 0.5rem; }
    .tools-sub { font-family: var(--font-jp); font-size: var(--text-body); font-weight: 300; color: var(--color-ink-muted-dark); }
    .tools-track-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; scroll-snap-type: x mandatory; scroll-behavior: smooth; }
    .tools-track-wrap::-webkit-scrollbar { height: 0; }
    .tools-track { display: flex; gap: 1.5rem; padding: 0 var(--pad) 1rem; }
    .tool-card { width: 300px; flex-shrink: 0; padding: 1.75rem; border: 1px solid rgba(255,255,255,0.06); border-radius: 3px; transition: border-color 0.3s, transform 0.3s; scroll-snap-align: start; }
    .tool-card:hover { border-color: rgba(196,168,130,0.25); transform: translateY(-3px); }
    .tool-logo { height: 20px; width: auto; filter: brightness(0) invert(1); opacity: 0.5; margin-bottom: 1rem; display: block; }
    .tool-tagline { font-family: var(--font-display); font-size: 0.55rem; font-weight: 600; letter-spacing: 0.2em; color: var(--color-accent-dark); text-transform: uppercase; display: block; margin-bottom: 0.25rem; }
    .tool-name { font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: var(--color-ink-dark); }
    .tool-screenshot { margin-top: 1.25rem; overflow: hidden; border-radius: 2px; border: 1px solid rgba(255,255,255,0.04); }
    .tool-screenshot img { width: 100%; height: auto; display: block; }

    /* ── BRIDGE ── */
    .bridge-section { padding: 8rem 0; border-top: 1px solid rgba(255,255,255,0.04); }
    .bridge-inner { max-width: var(--mw); margin: 0 auto; padding: 0 var(--pad); }
    .bridge-heading { font-family: var(--font-jp); font-size: clamp(1.3rem, 2.2vw, 1.8rem); font-weight: 700; color: var(--color-ink-dark); margin-bottom: 3rem; }
    .bridge-reasons { display: grid; grid-template-columns: 1fr; gap: 0; }
    @media (min-width: 768px) { .bridge-reasons { grid-template-columns: repeat(3, 1fr); } }
    .bridge-reason {
      padding: clamp(1.5rem, 3vw, 2.5rem);
      border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    @media (min-width: 768px) {
      .bridge-reason { border-bottom: none; border-right: 1px solid rgba(255,255,255,0.04); }
      .bridge-reason:last-child { border-right: none; }
    }
    .bridge-reason-num {
      font-family: var(--font-display); font-size: 0.8rem;
      font-weight: 600; letter-spacing: 0.15em; color: var(--color-accent-dark); opacity: 0.4;
      display: block; margin-bottom: 0.75rem; line-height: 1;
    }
    .bridge-reason-title { font-family: var(--font-jp); font-size: clamp(1rem, 1.5vw, 1.2rem); font-weight: 700; color: var(--color-ink-dark); margin-bottom: 0.5rem; }
    .bridge-reason p { font-family: var(--font-jp); font-size: var(--text-body); font-weight: 400; color: var(--color-ink-dark); opacity: 0.7; line-height: 2; }

    /* ── PERSONAL + VALUES ── */
    .personal-section { padding: 6rem 0; border-top: 1px solid rgba(255,255,255,0.04); }
    .personal-inner { max-width: var(--mw); margin: 0 auto; padding: 0 var(--pad); }
    .personal-layout {
      display: grid; grid-template-columns: 1fr; gap: 3rem;
    }
    @media (min-width: 768px) {
      .personal-layout { grid-template-columns: 220px 1fr; gap: clamp(3rem, 5vw, 5rem); align-items: start; }
    }
    .personal-photo { max-width: 220px; }
    .personal-img {
      width: 100%; height: auto; border-radius: 4px; display: block;
      filter: grayscale(0.15) contrast(1.05); margin-bottom: 1rem;
    }
    .personal-sign {}
    .personal-name {
      font-family: var(--font-jp); font-size: 1rem; font-weight: 700;
      color: var(--color-ink-dark); display: block; margin-bottom: 0.15rem;
    }
    .personal-role {
      font-family: var(--font-body); font-size: 0.8rem;
      color: var(--color-ink-muted-dark); letter-spacing: 0.05em;
    }
    .personal-text {}
    .personal-message {
      font-family: var(--font-jp); font-size: clamp(0.95rem, 1.2vw, 1.1rem);
      color: var(--color-ink-dark); opacity: 0.85; line-height: 2.2;
    }
    /* Values inside personal */
    .personal-values { margin-top: 4rem; padding-top: 3rem; border-top: 1px solid rgba(255,255,255,0.06); }
    .personal-values__heading {
      font-family: var(--font-display); font-size: 0.6rem; font-weight: 600;
      letter-spacing: 0.35em; text-transform: uppercase;
      color: var(--color-accent-dark); opacity: 0.5; margin-bottom: 2rem;
    }
    .personal-values__list {
      list-style: none; margin: 0; padding: 0;
      display: grid; grid-template-columns: 1fr; gap: 0;
    }
    @media (min-width: 768px) { .personal-values__list { grid-template-columns: repeat(2, 1fr); } }
    @media (min-width: 1200px) { .personal-values__list { grid-template-columns: repeat(5, 1fr); } }
    .personal-values__item {
      padding: clamp(1rem, 1.5vw, 1.25rem);
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    @media (min-width: 768px) {
      .personal-values__item { border-right: 1px solid rgba(255,255,255,0.04); }
      .personal-values__item:nth-child(2n) { border-right: none; }
    }
    @media (min-width: 1200px) {
      .personal-values__item:nth-child(2n) { border-right: 1px solid rgba(255,255,255,0.04); }
      .personal-values__item:last-child { border-right: none; }
    }
    .personal-values__title {
      font-family: var(--font-jp); font-size: clamp(0.9rem, 1.1vw, 1rem);
      font-weight: 700; color: var(--color-ink-dark); display: block; margin-bottom: 0.3rem;
    }
    .personal-values__criterion {
      font-family: var(--font-jp); font-size: 0.8rem;
      color: var(--color-ink-dark); opacity: 0.5; display: block;
    }

    /* ── CTA ── */
    .cta-section { padding: 6rem 0 10rem; }
    .cta-inner { max-width: var(--mw); margin: 0 auto; padding: 0 var(--pad); text-align: center; }
    .cta-line { width: 1px; height: 48px; background: linear-gradient(to bottom, transparent, var(--color-accent-dark), transparent); margin: 0 auto 2.5rem; }
    .cta-heading { font-family: var(--font-jp); font-size: clamp(1.3rem, 2.5vw, 2rem); font-weight: 700; color: var(--color-ink-dark); margin-bottom: 0.5rem; }
    .cta-sub { font-family: var(--font-jp); font-size: var(--text-body); font-weight: 300; color: var(--color-ink-muted-dark); margin-bottom: 2rem; }
    .cta-steps { display: flex; gap: 2rem; justify-content: center; margin-bottom: 2.5rem; flex-wrap: wrap; }
    .cta-step { display: flex; align-items: center; gap: 0.5rem; font-family: var(--font-jp); font-size: 0.85rem; color: var(--color-ink-dark); opacity: 0.6; }
    .cta-step-num { font-family: var(--font-display); font-size: 0.7rem; font-weight: 600; color: var(--color-accent-dark); opacity: 0.5; }
    .cta-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .cta-primary, .cta-outline { font-family: var(--font-jp); font-size: 0.82rem; font-weight: 500; letter-spacing: 0.06em; padding: 1rem 2.5rem; border-radius: 2px; text-decoration: none; display: inline-block; transition: all 0.25s ease; }
    .cta-primary { color: var(--color-surface-dark); background: var(--color-ink-dark); }
    .cta-primary:hover { opacity: 0.85; transform: translateY(-2px); }
    .cta-outline { color: var(--color-ink-dark); border: 1px solid rgba(240,238,235,0.15); }
    .cta-outline:hover { border-color: rgba(240,238,235,0.4); transform: translateY(-2px); }

    /* ── Responsive ── */
    /* value-item responsive handled above */
    @media (max-width: 767px) {
      .hero-grid-lines, .hero-scroll-hint { display: none; }
      .hero-proof { gap: 1.25rem; }
      .hero-proof-divider { display: none; }
      .cta-section { padding-bottom: calc(10rem + 56px + env(safe-area-inset-bottom, 0px)); }
      /* accordion is naturally responsive */
    }

    /* ── Reduced motion ── */
    @media (prefers-reduced-motion: reduce) {
      .hero-img { transform: none !important; }
      .vision-bg img { transform: none !important; }
      .m-line { opacity: 1 !important; }
      .value-item { opacity: 1 !important; transform: none !important; }
      /* accordion needs no noscript overrides */
    }
  </style>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import Lenis from 'lenis';
    gsap.registerPlugin(ScrollTrigger);

    let lenisInstance: Lenis | null = null;
    let tickerFn: ((time: number) => void) | null = null;
    let mm: gsap.MatchMedia | null = null;
    let observers: IntersectionObserver[] = [];

    function cleanup() {
      observers.forEach(o => o.disconnect());
      observers = [];
      if (mm) { mm.revert(); mm = null; }
      ScrollTrigger.getAll().forEach(t => t.kill());
      if (tickerFn) { gsap.ticker.remove(tickerFn); tickerFn = null; }
      if (lenisInstance) { lenisInstance.destroy(); lenisInstance = null; }
    }

    /* showAllLevels removed — accordion doesn't need it */

    function init() {
      cleanup();

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Only init Lenis if motion is allowed
      if (!prefersReduced) {
        lenisInstance = new Lenis({ duration: 1.1, easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
        lenisInstance.on('scroll', ScrollTrigger.update);
        tickerFn = (time: number) => lenisInstance?.raf(time * 1000);
        gsap.ticker.add(tickerFn);
        gsap.ticker.lagSmoothing(0);
      }

      if (prefersReduced) {
        document.querySelectorAll('.reveal').forEach(el => el.classList.add('visible'));
        document.querySelectorAll('.m-line').forEach(el => (el as HTMLElement).classList.add('is-visible'));
        document.querySelectorAll('.value-item').forEach(el => { (el as HTMLElement).style.opacity = '1'; (el as HTMLElement).style.transform = 'none'; });
        gsap.set(['.hero-logo', '.hero-sub', '.hero-proof'], { opacity: 1 });
        gsap.set('.hero-img', { scale: 1 });
        /* accordion needs no reduced-motion override */
        return;
      }

      // ── Reveals (tracked for cleanup) ──
      document.querySelectorAll('.reveal').forEach(el => {
        const obs = new IntersectionObserver(([e]) => { if (e.isIntersecting) { el.classList.add('visible'); obs.disconnect(); } }, { threshold: 0.12 });
        obs.observe(el); observers.push(obs);
      });

      const ease = 'power3.out';

      // ── Match media for responsive GSAP (stored for proper cleanup) ──
      mm = gsap.matchMedia();
      mm.add('(min-width: 768px)', () => {
        // HERO
        const heroTl = gsap.timeline({ delay: 0.2 });
        heroTl
          .to('.hero-img', { scale: 1, duration: 2.2, ease: 'power2.out' }, 0)
          .to('.hero-logo', { opacity: 0.5, duration: 0.7, ease }, 0.15)
          .from('.hero-word', { y: '110%', duration: 0.9, ease: 'power4.out', stagger: 0.12 }, 0.35)
          .to('.hero-sub', { opacity: 1, duration: 0.7, ease }, 1)
          .to('.hero-proof', { opacity: 1, duration: 0.7, ease }, 1.15)
          .to('.hero-scroll-hint', { opacity: 0.5, duration: 0.6, ease }, 1.5);

        gsap.to('.hero-overlay', { background: 'rgba(12,12,12,0.92)', scrollTrigger: { trigger: '.hero-wrap', start: 'top top', end: '70% top', scrub: true } });
        gsap.to('.hero-img', { y: '12%', scrollTrigger: { trigger: '.hero-wrap', start: 'top top', end: 'bottom top', scrub: true } });
        gsap.to('.hero-scroll-hint', { opacity: 0, scrollTrigger: { trigger: '.hero-wrap', start: '12% top', end: '22% top', scrub: true } });

        // MANIFESTO
        document.querySelectorAll('.m-line:not(.m-break)').forEach((line, i) => {
          ScrollTrigger.create({ trigger: '.manifesto', start: `${12 + i * 10}% center`, once: true, onEnter: () => { gsap.to(line, { opacity: 1, duration: 0.6, ease: 'power2.out' }); line.classList.add('is-visible'); } });
        });

        // VISION PARALLAX
        gsap.to('.vision-img', { y: '-10%', scrollTrigger: { trigger: '.vision', start: 'top bottom', end: 'bottom top', scrub: 0.5 } });

        // ── SERVICE — architectural section drawing ──
        /* SERVICE: accordion needs no GSAP — native <details> handles it */

        // VALUES — set initial state then animate in
        document.querySelectorAll('.value-item').forEach((item, i) => {
          gsap.set(item, { opacity: 0, y: 20 });
          gsap.to(item, { opacity: 1, y: 0, duration: 0.6, ease, scrollTrigger: { trigger: item, start: 'top 88%' }, delay: i * 0.05 });
        });

        // TOOLS stagger
        gsap.from('.tool-card', { x: 50, opacity: 0, stagger: 0.08, duration: 0.7, ease, scrollTrigger: { trigger: '.tools-section', start: 'top 75%' } });

        return () => {};
      });

      mm.add('(max-width: 767px)', () => {
        gsap.set(['.hero-logo', '.hero-sub', '.hero-proof'], { opacity: 1 });
        gsap.set('.hero-img', { scale: 1 });
        gsap.from('.hero-word', { y: '100%', duration: 0.8, ease: 'power4.out', stagger: 0.1, delay: 0.2 });

        document.querySelectorAll('.m-line:not(.m-break)').forEach(line => {
          const obs = new IntersectionObserver(([e]) => { if (e.isIntersecting) { (line as HTMLElement).style.opacity = '1'; line.classList.add('is-visible'); obs.disconnect(); } }, { threshold: 0.3 });
          obs.observe(line); observers.push(obs);
        });

        document.querySelectorAll('.value-item').forEach(item => {
          const obs = new IntersectionObserver(([e]) => { if (e.isIntersecting) { (item as HTMLElement).style.opacity = '1'; (item as HTMLElement).style.transform = 'none'; obs.disconnect(); } }, { threshold: 0.2 });
          obs.observe(item); observers.push(obs);
        });

        /* accordion: mobile needs no special JS */

        return () => {};
      });
    }

    import { registerPageInit } from '../../lib/scroll-engine';
    registerPageInit(init);
  </script>
</Layout>
