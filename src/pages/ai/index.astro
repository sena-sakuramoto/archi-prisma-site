      }
      .ai-values__num {
        font-size: 0.72rem;
        opacity: 0.75;
        margin-bottom: 0.6rem;
        color: rgba(231, 193, 143, 0.92);
      }
      .ai-values__title {
        font-size: 1.28rem;
        line-height: 1.25;
        margin-bottom: 0.5rem;
      }
      .ai-values__criterion {
