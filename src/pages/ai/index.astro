        const svcArch = document.querySelector('.svc-arch') as HTMLElement;
        const scanline = document.querySelector('.svc-arch__scanline') as HTMLElement;
        const levels = document.querySelectorAll<HTMLElement>('.svc-arch__level');
        const levelKeys = ['entry', 'org', 'retain', 'demand'];
        const thresholds = [0, 0.25, 0.5, 0.75]; // progress at which each level activates

