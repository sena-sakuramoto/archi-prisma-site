      .ai-outcome {
        font-size: clamp(1.85rem, 8.5vw, 2.35rem) !important;
        line-height: 1.16;
        letter-spacing: -0.03em;
      }
      .ai-kpi-group {
        width: 100%;
        display: grid !important;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
        align-items: start !important;
      }
      .ai-kpi__value { font-size: 1.95rem; }
      .ai-kpi__divider { display: none; }
      .ai-kpi { min-width: 0; }
      .ai-kpi__label { font-size: 0.78rem; }
      .m-line--muted { line-height: 2.2; color: rgba(240, 238, 235, 0.74); }
      .m-line--bold { line-height: 1.55; }
      .m-line--accent { line-height: 1.45; }
      .ai-vision__point-text { color: rgba(240, 238, 235, 0.76) !important; }
      .ai-service__heading {
        font-size: clamp(2rem, 9.4vw, 2.45rem) !important;
