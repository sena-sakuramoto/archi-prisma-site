      }
      .ai-personal__media,
      .ai-personal__copy-wrap {
        padding: 0 !important;
      }
      .ai-personal__image {
        border-radius: 18px !important;
      }
      .ai-personal__meta {
        margin-top: 0.9rem !important;
      }
      .ai-personal__name {
