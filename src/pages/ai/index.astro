      .ai-hero__title { font-size: clamp(2.35rem, 10vw, 3.5rem) !important; line-height: 1.08 !important; }
      .ai-hero .line-section { min-height: 100vh !important; min-height: 100svh !important; }
      .ai-page .section-pad:last-of-type { padding-bottom: clamp(4rem, 8vw, 8rem); }
      .ai-proof__heading {
