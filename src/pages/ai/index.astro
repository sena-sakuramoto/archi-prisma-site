          imgSlides.forEach((el, i) => { if (i > 0) el.setAttribute('aria-hidden', 'true'); });

          let current = 0;
          function goTo(idx: number) {
            if (idx === current || idx < 0 || idx >= total) return;
            const dir = idx > current ? 1 : -1;
            const prev = current;
            current = idx; // Update synchronously to prevent race conditions

            // Outgoing: text + image + aria
            const outText = textSlides[prev]!;
            outText.setAttribute('aria-hidden', 'true');
            gsap.to(outText, { opacity: 0, y: -15 * dir, duration: 0.3, ease: 'power2.in', onComplete() { outText.style.pointerEvents = 'none'; } });
            imgSlides[prev]!.setAttribute('aria-hidden', 'true');
            gsap.to(imgSlides[prev], { opacity: 0, duration: 0.35, ease: 'power2.in' });

            // Incoming: text + image + aria
            const inText = textSlides[idx]!;
            inText.removeAttribute('aria-hidden');
            inText.style.pointerEvents = 'auto';
            gsap.set(inText, { opacity: 1 });
            gsap.fromTo(inText.querySelectorAll('.svc-tagline,.svc-name,.svc-desc,.svc-price'), { opacity: 0, y: 20 * dir }, { opacity: 1, y: 0, stagger: 0.06, duration: 0.45, ease, delay: 0.12 });
            imgSlides[idx]!.removeAttribute('aria-hidden');
            gsap.fromTo(imgSlides[idx], { opacity: 1, clipPath: dir > 0 ? 'inset(0 100% 0 0)' : 'inset(0 0 0 100%)' }, { clipPath: 'inset(0 0% 0 0%)', duration: 0.6, ease: 'power3.out', delay: 0.06 });

            // Update journey indicator
            if (journeyFill) journeyFill.style.width = `${((idx + 0.5) / total) * 100}%`;
            journeyDots.forEach((dot, j) => {
              dot.classList.toggle('svc-journey__dot--active', j <= idx);
            });
            if (counterNum) { gsap.to(counterNum, { y: -8, opacity: 0, duration: 0.12, onComplete() { counterNum!.textContent = String(idx + 1).padStart(2, '0'); gsap.fromTo(counterNum, { y: 8, opacity: 0 }, { y: 0, opacity: 0.4, duration: 0.25 }); } }); }

            // Update step label
            const stepLabel = document.getElementById('svc-step-label');
            const stepText = inText.getAttribute('data-step') || '';
            if (stepLabel && stepText) {
              gsap.to(stepLabel, { opacity: 0, duration: 0.15, onComplete() { stepLabel.textContent = stepText; gsap.to(stepLabel, { opacity: 1, duration: 0.25 }); } });
            }
          }

          svcSection.style.height = `${total * 100}vh`;
          ScrollTrigger.create({ trigger: svcSection, start: 'top top', end: 'bottom bottom', pin: svcPinWrap, pinSpacing: false, onUpdate(self) { const idx = Math.min(Math.floor(self.progress * total), total - 1); if (idx !== current) goTo(idx); } });
        }

        // VALUES
        document.querySelectorAll('.value-item').forEach((item, i) => {
          gsap.to(item, { opacity: 1, y: 0, duration: 0.6, ease, scrollTrigger: { trigger: item, start: 'top 88%' }, delay: i * 0.05 });
        });

        // TOOLS stagger
        gsap.from('.tool-card', { x: 50, opacity: 0, stagger: 0.08, duration: 0.7, ease, scrollTrigger: { trigger: '.tools-section', start: 'top 75%' } });

        return () => {};
      });

      mm.add('(max-width: 767px)', () => {
        gsap.set(['.hero-logo', '.hero-sub', '.hero-proof'], { opacity: 1 });
        gsap.set('.hero-img', { scale: 1 });
        gsap.from('.hero-word', { y: '100%', duration: 0.8, ease: 'power4.out', stagger: 0.1, delay: 0.2 });

        document.querySelectorAll('.m-line:not(.m-break)').forEach(line => {
          const obs = new IntersectionObserver(([e]) => { if (e.isIntersecting) { (line as HTMLElement).style.opacity = '1'; line.classList.add('is-visible'); obs.disconnect(); } }, { threshold: 0.3 });
