    .ai-values__num { font-family: var(--font-display); font-size: 0.65rem; font-weight: 600; letter-spacing: 0.1em; color: var(--color-accent-dark); opacity: 0.4; display: block; margin-bottom: 0.75rem; }
    .ai-values__title { font-family: var(--font-display), var(--font-jp); font-size: clamp(0.95rem, 1.2vw, 1.1rem); font-weight: 700; color: var(--color-ink-dark); display: block; margin-bottom: 0.4rem; line-height: 1.5; }
    .ai-values__criterion { font-family: var(--font-body), var(--font-jp); font-size: var(--text-caption); font-weight: 400; color: var(--color-ink-dark); opacity: 0.5; line-height: 1.8; display: block; }

    /* ── Responsive ── */
    @media (max-width: 767px) {
      .ai-hero { height: auto; }
      .ai-hero__sticky { position: relative; }
      .ai-hero__content {
        align-items: center;
        padding-top: 60px;
      }
      .ai-hero__inner {
        width: 100%;
        max-width: none;
        padding: clamp(104px, 22vw, 148px) 0 clamp(28px, 10vw, 48px);
      }
