      }
      .ai-svc__recommend-label {
        font-size: 0.72rem;
        min-height: 26px;
      }
      .ai-svc__recommend-text {
        font-size: 0.98rem;
        line-height: 1.72;
      }
      .ai-svc__desc {
        font-size: 0.98rem !important;
