      border: 1px solid rgba(240,238,235,0.15);
      background: transparent;
    }

    /* ── FAQ ── */
    .ai-faq__list {
      border-top: 1px solid rgba(255,255,255,0.08);
    }
    .ai-faq__item {
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .ai-faq__question {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.85rem;
      align-items: start;
      padding: 1.25rem 0;
