    }

    function showAllServices() {
      document.querySelectorAll<HTMLElement>('.svc-slide-text').forEach(el => {
        el.style.position = 'relative'; el.style.opacity = '1'; el.style.pointerEvents = 'auto';
        el.style.marginBottom = '2.5rem'; el.removeAttribute('aria-hidden');
