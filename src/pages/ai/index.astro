      if (prefersReduced) {
        document.querySelectorAll('.reveal').forEach(el => el.classList.add('visible'));
        document.querySelectorAll('.m-line').forEach(el => (el as HTMLElement).classList.add('is-visible'));
        document.querySelectorAll('.value-item').forEach(el => { (el as HTMLElement).style.opacity = '1'; (el as HTMLElement).style.transform = 'none'; });
        gsap.set(['.hero-logo', '.hero-sub', '.hero-proof'], { opacity: 1 });
        gsap.set('.hero-img', { scale: 1 });
        showAllServices();
        // Also apply mobile service reset (for small-screen + reduced-motion)
        const svc = document.querySelector('.svc-section') as HTMLElement;
        if (svc) {
          svc.style.height = 'auto';
          document.querySelector('.svc-counter')?.setAttribute('style', 'display:none');
          document.querySelector('.svc-progress')?.setAttribute('style', 'display:none');
          document.querySelector('.svc-pinned')?.setAttribute('style', 'height:auto; display:block;');
          const imgArea = document.querySelector('.svc-image-area') as HTMLElement;
          if (imgArea) { imgArea.style.position = 'relative'; imgArea.style.aspectRatio = 'auto'; imgArea.style.display = 'flex'; imgArea.style.flexDirection = 'column'; }
        }
