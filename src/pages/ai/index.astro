    /* ── CTA buttons ── */
    .ai-cta__actions {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .ai-cta__button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 280px;
      min-height: 60px;
      padding: 0 2rem;
      border-radius: 2px;
