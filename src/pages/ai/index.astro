    /* ── VALUES ── */
    .ai-values__list {
      list-style: none; margin: 0; padding: 0;
      display: grid; grid-template-columns: 1fr; gap: 0;
    }
    @media (min-width: 768px) { .ai-values__list { grid-template-columns: repeat(2, 1fr); } }
    @media (min-width: 1200px) { .ai-values__list { grid-template-columns: repeat(5, 1fr); } }
    .ai-values__item {
      padding: clamp(1.25rem, 2vw, 1.5rem);
