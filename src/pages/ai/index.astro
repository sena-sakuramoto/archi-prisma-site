      padding: 1.1rem 1rem 0.95rem;
      border: 1px solid rgba(214, 171, 116, 0.26);
      background: linear-gradient(180deg, rgba(214, 171, 116, 0.14) 0%, rgba(214, 171, 116, 0.08) 100%);
      border-radius: 18px;
      box-shadow: 0 14px 30px rgba(0,0,0,0.18);
    }
    .ai-svc__recommend::after {
      content: '';
      position: absolute;
      left: 1.25rem;
      bottom: -10px;
      width: 18px;
      height: 18px;
      background: linear-gradient(135deg, rgba(214, 171, 116, 0.14) 0%, rgba(214, 171, 116, 0.08) 100%);
      border-right: 1px solid rgba(214, 171, 116, 0.22);
      border-bottom: 1px solid rgba(214, 171, 116, 0.22);
