          showAllServices(); // removes aria-hidden + shows all content
          document.querySelectorAll<HTMLElement>('.svc-slide-img').forEach((el, i) => {
            el.style.marginBottom = i < 4 ? '3rem' : '0';
          });
          const imgArea = document.querySelector('.svc-image-area') as HTMLElement;
          if (imgArea) { imgArea.style.position = 'relative'; imgArea.style.aspectRatio = 'auto'; imgArea.style.display = 'flex'; imgArea.style.flexDirection = 'column'; imgArea.style.gap = '0'; }
          document.querySelector('.svc-counter')?.setAttribute('style', 'display:none');
          document.querySelector('.svc-progress')?.setAttribute('style', 'display:none');
          document.querySelector('.svc-pinned')?.setAttribute('style', 'height:auto; display:block;');
        }

        return () => {};
      });
