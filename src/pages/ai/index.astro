        });

        document.querySelectorAll('.value-item').forEach(item => {
          const obs = new IntersectionObserver(([e]) => { if (e.isIntersecting) { (item as HTMLElement).style.opacity = '1'; (item as HTMLElement).style.transform = 'none'; obs.disconnect(); } }, { threshold: 0.2 });
