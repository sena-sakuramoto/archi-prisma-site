      }
      .ai-faq__list {
        margin-top: 1.5rem;
      }
      .ai-faq__question {
        padding: 1rem 0;
        font-size: 1rem;
        gap: 0.75rem;
      }
      .ai-faq__qmark {
        width: 1.6rem;
        height: 1.6rem;
