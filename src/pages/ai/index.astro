        color: rgba(240, 238, 235, 0.78);
        opacity: 1;
      }
      .ai-cta__actions {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.85rem;
      }
      .ai-cta__button {
        width: 100%;
